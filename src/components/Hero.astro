---
import { tv, type VariantProps } from "tailwind-variants";

interface Props extends VariantProps<typeof styles> {
  class?: string;
}

const styles = tv({
  base: "breakout py-lg",
  variants: {
    level: {
      root: "bg-cosmic-blue-base text-white",
      main: "bg-lavender-400",
      sub: "bg-lavender-200",
    },
  },
  defaultVariants: {
    level: "sub",
  },
});

const { class: className, level } = Astro.props;
const hasSubtitle = Astro.slots.has("subtitle");
---

<div class={styles({ level, className })}>
  <slot />
  {
    hasSubtitle && (
      <div>
        <slot name="subtitle" />
      </div>
    )
  }
</div>
