---
import { getSectionLinks } from "@/config/routes";

const { pathname } = Astro.url;
const sectionLinks = getSectionLinks(pathname);
---

{
  sectionLinks.length > 0 && (
    <nav
      aria-label="Seitenleistennavigation"
      class="bg-lavender-200 p-20 max-lg:hidden"
    >
      <ul class="list-unstyled space-y-8">
        {sectionLinks.map((link) => (
          <li>
            <a
              href={link.path}
              aria-current={pathname === link.path ? "page" : undefined}
            >
              {link.title}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  @reference "@/styles/global.css";
  a {
    @apply block rounded-xl px-16 py-8 no-underline;

    &:hover:not([aria-current="page"]) {
      @apply bg-white;
    }

    &[aria-current="page"] {
      @apply bg-cosmic-blue-base font-semibold text-white;
    }
  }
</style>
