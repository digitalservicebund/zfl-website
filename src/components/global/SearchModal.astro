---
import PagefindConfig from "astro-pagefind/components/PagefindConfig.astro";
---

<>
  <PagefindConfig highlight-param="highlight" />
  <pagefind-modal>
    <pagefind-modal-header>
      <pagefind-input></pagefind-input>
    </pagefind-modal-header>
    <pagefind-modal-body>
      <search-modal-summary></search-modal-summary>
      <pagefind-results hide-sub-results></pagefind-results>
    </pagefind-modal-body>
    <pagefind-modal-footer>
      <pagefind-keyboard-hints></pagefind-keyboard-hints>
    </pagefind-modal-footer>
  </pagefind-modal>
</>

<script src="./SearchModalSummary.ts"></script>

<script
  is:inline
  type="module"
  define:vars={{ baseUrl: import.meta.env.BASE_URL }}
>
  // change event to "astro:page-load" if using Astro's ClientRouter
  document.addEventListener("DOMContentLoaded", async () => {
    const base = baseUrl === "/" ? "" : baseUrl;
    await import(`${base}/pagefind/pagefind-highlight.js`);
    new PagefindHighlight({ highlightParam: "highlight" });
    const firstMatch = document.querySelector("mark.pagefind-highlight");
    firstMatch?.scrollIntoView({ behavior: "smooth", block: "center" });
  });
</script>

<style is:global>
  /* https://pagefind.app/docs/css-variables/ */

  :root {
    /* Colors */
    --pf-text: var(--kern-color-layout-text-default);
    --pf-text-secondary: var(--kern-color-layout-text-muted);
    --pf-text-muted: var(--kern-color-layout-text-muted);
    --pf-border: var(--kern-color-decorative-border-contextual, #c0c3d5);
    --pf-outline-focus: var(--color-cosmic-blue-base);
    --pf-mark: var(--kern-color-layout-text-default);
    --pf-skeleton: var(--color-lavender-200);

    /* Typography */
    --pf-font: var(--kern-typography-font-family-default);

    /* Sizing */
    --pf-input-font-size: var(--kern-typography-font-size-static-medium);
    --pf-input-height: 43px;
    --pf-result-title-font-size: var(--kern-typography-font-size-static-medium);
    --pf-result-excerpt-font-size: var(
      --kern-typography-font-size-static-small
    );
    --pf-results-gap: var(--kern-metric-space-default);
    --pf-summary-font-size: var(--kern-typography-font-size-static-small);

    /* Results layout */
    --pf-border-radius: var(--kern-metric-border-radius-default, 4px);

    /* Modal */
    --pf-modal-max-width: 720px;
  }

  :is(*, #\#):is(*, #\#) :is([class^="pf-"]) {
    -webkit-font-smoothing: antialiased;
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) dialog.pf-modal {
    border-radius: var(--kern-metric-border-radius-large, 8px);
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-trigger-text {
    font-size: var(--kern-typography-font-size-static-medium);
    font-family: var(--kern-typography-font-family-default);
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-result-excerpt {
    white-space: normal;
    mark {
      background-color: var(--kern-color-feedback-success-background);
    }
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-keyboard-hint,
  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-input-clear,
  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-keyboard-key {
    font-size: var(--kern-typography-font-size-static-small);
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-keyboard-key {
    height: 24px;
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-modal-footer {
    padding: var(--kern-metric-space-default);
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-modal-body .pf-summary {
    margin: var(--kern-metric-space-small) 0;
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-error {
    display: none; /* using custom error messages in SearchModalSummary.ts */
  }

  mark.pagefind-highlight {
    background-color: var(--kern-color-feedback-success-background);
  }
</style>
