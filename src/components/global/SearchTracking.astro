<script>
  import posthog from "posthog-js";

  const inputElement =
    document.querySelector<HTMLInputElement>("input.pf-input");

  function debounce(func: (v: string) => void, delay: number) {
    let timeoutId: NodeJS.Timeout;
    return (v: string) => {
      clearTimeout(timeoutId);
      timeoutId = setTimeout(() => func(v), delay);
    };
  }

  const trackSearch = debounce((value: string) => {
    const query = value.trim();
    if (query.length > 3) {
      posthog.capture("search_input", { query });
    }
  }, 500);

  inputElement?.addEventListener("input", (e) => {
    if (!(e.target instanceof HTMLInputElement)) return;
    trackSearch(e.target.value);
  });
</script>
