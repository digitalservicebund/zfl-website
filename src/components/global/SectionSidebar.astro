---
import DrilldownNavigation from "@/components/global/DrilldownNavigation.astro";
import { getSectionNavigation } from "@/utils/navigation/drilldown";

const navigation = getSectionNavigation(Astro.url.pathname);
const initialDepth = navigation?.activePanel.depth;
const sidebarState = navigation
  ? `{ currentPanel: "${navigation.activePanel.id}", currentDepth: ${initialDepth} }`
  : null;
---

{
  navigation && (
    <nav
      aria-label="Abschnittsnavigation"
      class="data-[depth=1]:bg-form-input-background bg-lavender-base hidden border-r border-neutral-300 min-[900px]:flex min-[900px]:flex-col"
      x-data={sidebarState}
      data-depth={initialDepth}
      x-bind:data-depth="currentDepth"
    >
      <div class="sticky top-0">
        <DrilldownNavigation
          navigation={navigation}
          panelIdPrefix="section-sidebar"
        />
      </div>
      {Astro.slots.has("extra") && (
        <div class="sticky bottom-0 mt-auto">
          <slot name="extra" />
        </div>
      )}
    </nav>
  )
}

<style>
  nav[data-depth="1"] {
    --active-item-bg-color: var(--color-lavender-surface-highlight);
  }
</style>
