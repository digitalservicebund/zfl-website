---
import DrilldownNavigation from "@/components/global/DrilldownNavigation.astro";
import Kopfzeile from "@/components/global/Kopfzeile.astro";
import { ZFL_EMAIL, ZFL_PHONE } from "@/config/constants";
import {
  begleitungen,
  home,
  schulungen,
  ueber,
  werkzeuge,
  type Route,
} from "@/config/routes";
import bundLogoWhite from "@/images/logo/bund-logo-white.svg";
import bundLogo from "@/images/logo/bund-logo.png";
import { getMobileMenuNavigation } from "@/utils/navigation/drilldown";
import { getRouteLabel, isRouteVisible } from "@/utils/navigation/routeUtils";
import { removeTrailingSlash } from "@/utils/path";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { twMerge } from "tailwind-merge";

const { pathname } = Astro.url;
const currentPath = removeTrailingSlash(pathname);

const HEADER_ROUTES: Route[] = [werkzeuge, begleitungen, schulungen, ueber];
const headerNavigation = HEADER_ROUTES.filter(isRouteVisible);
const mobileMenu = getMobileMenuNavigation(currentPath, headerNavigation);

const mobileMenuInitialDepth = mobileMenu.activePanel.depth;

const mobileMenuId = "page-header-mobile-menu";

function navItemStyle(variant: "main" | "sub" = "main", active = false) {
  return twMerge(
    "link-unstyled border-transparent flex items-center hover:bg-lavender-base",
    variant === "main" ? "h-full border-b-4 px-16" : "border-l-4 p-16",
    active && "border-cosmic-blue-base bg-lavender-base",
  );
}
---

<header
  class="page-header border-lavender-base relative border-b-2"
  x-data={`{
    mobileMenuOpen: false,
    kontaktOpen: false
  }`}
  @resize.window="mobileMenuOpen = false; kontaktOpen = false"
  @keydown.escape.window="mobileMenuOpen = false; kontaktOpen = false"
>
  <Kopfzeile />
  <div class="flex h-72 justify-between px-24">
    <!-- Logo and title -->
    <a href={home.path} class="link-unstyled flex items-center gap-24">
      <Image
        src={bundLogo}
        alt="Logo des Bundes"
        class="w-56 forced-colors:dark:hidden"
      />
      <Image
        src={bundLogoWhite}
        alt="Logo des Bundes"
        class="hidden w-56 forced-colors:dark:block"
      />
      <p class="text-xl font-bold max-[1050px]:hidden">Zentrum für Legistik</p>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden min-[900px]:flex" aria-label="Hauptnavigation">
      {
        headerNavigation.map((route) => (
          <a
            href={route.path}
            class={navItemStyle("main", currentPath === route.path)}
            aria-current={currentPath === route.path ? "page" : undefined}
          >
            {getRouteLabel(route)}
          </a>
        ))
      }
      <div
        class="relative flex h-full items-center"
        @click.outside="kontaktOpen = false"
      >
        <button
          type="button"
          class={navItemStyle()}
          @click="kontaktOpen = !kontaktOpen; mobileMenuOpen = false"
          :aria-expanded="kontaktOpen"
          aria-haspopup="true"
        >
          Kontakt
          <Icon
            name="ic:outline-keyboard-arrow-down"
            class="ml-4 size-24 transition-transform"
            :class="{ 'rotate-180': kontaktOpen }"
            aria-hidden="true"
          />
        </button>
        <div
          x-cloak
          x-show="kontaktOpen"
          class="contact-popover border-lavender-base m-0 gap-8 border-2 bg-white px-16 py-12 text-nowrap"
        >
          <p>Telefon: <a href={ZFL_PHONE.url}>{ZFL_PHONE.display}</a></p>
          <p>
            E-Mail:
            <a href={ZFL_EMAIL.url}>{ZFL_EMAIL.display}</a>
          </p>
        </div>
      </div>
    </nav>

    <!-- Mobile Menu Toggle -->
    <div class="flex min-[900px]:hidden">
      <a
        href={ZFL_PHONE.url}
        class={navItemStyle("main")}
        aria-label={ZFL_PHONE.display}
      >
        <Icon name="ic:twotone-phone-enabled" class="size-24 -scale-x-100" />
      </a>
      <button
        type="button"
        class:list={[navItemStyle("main"), "mobile-menu-toggle"]}
        aria-label="Menü öffnen / schließen"
        aria-controls={mobileMenuId}
        :aria-expanded="mobileMenuOpen"
        @click="mobileMenuOpen = !mobileMenuOpen; kontaktOpen = false; if (mobileMenuOpen) $dispatch('page-header-mobile-menu-opened')"
      >
        <Icon x-show="!mobileMenuOpen" name="ic:twotone-menu" class="size-24" />
        <Icon x-show="mobileMenuOpen" name="ic:outline-close" class="size-24" />
      </button>
    </div>
  </div>
  <div
    x-cloak
    x-show="mobileMenuOpen"
    class="mobile-menu-backdrop fixed inset-x-0 bottom-0 z-10 bg-black/40 min-[900px]:hidden"
    @click="mobileMenuOpen = false"
    aria-hidden="true"
  >
  </div>
  <!-- Mobile Navigation -->
  <nav
    id={mobileMenuId}
    class:list={[
      "mobile-menu-popover border-lavender-base m-0 w-auto max-w-none border-t-2 min-[900px]:hidden",
      {
        "bg-white": mobileMenuInitialDepth === 0,
        "bg-lavender-200": mobileMenuInitialDepth === 1,
        "bg-lavender-base": mobileMenuInitialDepth >= 2,
      },
    ]}
    x-data={`{ currentPanel: "${mobileMenu.activePanel.id}", initialPanel: "${mobileMenu.activePanel.id}", currentDepth: ${mobileMenuInitialDepth}, initialDepth: ${mobileMenuInitialDepth} }`}
    x-cloak
    x-show="mobileMenuOpen"
    :aria-hidden="!mobileMenuOpen"
    @page-header-mobile-menu-opened.window="currentPanel = initialPanel; currentDepth = initialDepth"
    :class={`{ 'bg-white': currentDepth === 0, 'bg-lavender-200': currentDepth === 1, 'bg-lavender-base': currentDepth >= 2 }`}
  >
    <DrilldownNavigation
      navigation={mobileMenu}
      panelIdPrefix="mobile-menu"
      rootPanelId="root"
    >
      <div slot="root-footer" class="px-12 text-gray-800">
        Kontakt: <a href={ZFL_EMAIL.url}>{ZFL_EMAIL.display}</a>
      </div>
    </DrilldownNavigation>
  </nav>
</header>

<style>
  .page-header {
    /* 32px is the height of the Kopfzeile, 72px is the height of the header */
    --page-header-offset: 104px;
  }

  .mobile-menu-backdrop {
    top: var(--page-header-offset);
  }

  .contact-popover {
    position: absolute;
    top: calc(100% - 2px);
    right: 0;
    z-index: 50;
  }

  .mobile-menu-popover {
    position: absolute;
    top: calc(var(--page-header-offset) - 2px);
    right: 0;
    left: 0;
    z-index: 20;
  }

  [x-cloak] {
    display: none !important;
  }
</style>
