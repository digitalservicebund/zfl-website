---
import Kopfzeile from "@/components/global/Kopfzeile.astro";
import { ZFL_EMAIL, ZFL_PHONE } from "@/config/constants";
import { routes } from "@/config/routes";
import { isStaging } from "@/config/stage";
import bundLogoWhite from "@/images/logo/bund-logo-white.svg";
import bundLogo from "@/images/logo/bund-logo.png";
import { removeTrailingSlash } from "@/utils/path";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { twMerge } from "tailwind-merge";

const { pathname } = Astro.url;
const currentPath = removeTrailingSlash(pathname);

const headerNavigation = [
  routes.werkzeuge,
  routes.begleitungen,
  routes.schulungen,
  routes.ueberDasZfl,
].filter((item) => isStaging || !item.isStagingOnly);

function getNavLinkClasses(itemPath: string, variant: "desktop" | "mobile") {
  return twMerge(
    "flex items-center hover:bg-lavender-base link-unstyled",
    variant === "desktop"
      ? "relative h-full border-b-4 border-transparent px-16 whitespace-nowrap"
      : "border-l-4 border-transparent p-16",
    currentPath === itemPath && "border-cosmic-blue-base bg-lavender-base",
  );
}
---

<header
  class="border-lavender-base relative border-b-2"
  x-data="{ mobileMenuOpen: false }"
  @resize.window="mobileMenuOpen = false"
>
  <Kopfzeile />
  <div class="flex h-72 justify-between px-24">
    <!-- Logo and title -->
    <a href={routes.home.path} class="link-unstyled flex items-center gap-8">
      <Image
        src={bundLogo}
        alt="Logo des Bundes"
        class="w-56 forced-colors:dark:hidden"
      />
      <Image
        src={bundLogoWhite}
        alt="Logo des Bundes"
        class="hidden w-56 forced-colors:dark:block"
      />
      <p
        class="ml-16 flex flex-col text-xl font-bold text-black md:max-[1050px]:hidden"
      >
        Zentrum für Legistik
      </p>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden items-center min-[900px]:flex" data-testid="desktop-nav">
      {
        headerNavigation.map((item) => (
          <a href={item.path} class={getNavLinkClasses(item.path, "desktop")}>
            {item.title}
          </a>
        ))
      }
      <div
        class="relative flex h-full items-center"
        x-data="{ kontaktOpen: false }"
        @click.outside="kontaktOpen = false"
      >
        <button
          type="button"
          class="hover:bg-lavender-base flex h-full cursor-pointer items-center border-b-4 border-transparent px-16 text-nowrap"
          @click="kontaktOpen = !kontaktOpen"
          :aria-expanded="kontaktOpen"
          aria-haspopup="true"
        >
          Kontakt
          <span
            class="kern-icon kern-icon--arrow-down ml-4 transition-transform"
            :class="{ 'rotate-180': kontaktOpen }"
            aria-hidden="true"></span>
        </button>
        <div
          x-show="kontaktOpen"
          style="display: none;"
          class="border-lavender-base absolute top-full right-0 z-50 flex flex-col gap-8 border bg-white px-16 py-12 text-nowrap shadow-sm"
        >
          <div>Support: <a href={ZFL_PHONE.url}>{ZFL_PHONE.display}</a></div>
          <div>
            Per Mail:
            <a href={ZFL_EMAIL.url}>{ZFL_EMAIL.display}</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Mobile View Controls -->
    <div class="flex items-center space-x-16 min-[900px]:hidden">
      <a
        href={ZFL_PHONE.url}
        class="border-b-4 border-transparent link-unstyled"
        aria-label={ZFL_PHONE.display}
      >
        <Icon name="ic:twotone-phone-enabled" class="size-24 -scale-x-100" />
      </a>
      <button
        class="hover:bg-lavender-base aria-expanded:border-cosmic-blue-base aria-expanded:bg-lavender-base h-full border-b-4 border-transparent px-16"
        @click="mobileMenuOpen = !mobileMenuOpen"
        type="button"
        aria-label="Menü öffnen / schließen"
        :aria-expanded="mobileMenuOpen"
        aria-controls="mobile-menu"
      >
        <Icon x-show="!mobileMenuOpen" name="ic:twotone-menu" class="size-24" />
        <Icon
          x-show="mobileMenuOpen"
          name="ic:twotone-menu-open"
          class="size-24"
          style="display: none;"
        />
      </button>
    </div>
  </div>
  <!-- Mobile Navigation -->
  <nav
    id="mobile-menu"
    class="absolute right-0 left-0 z-20 bg-white drop-shadow-[4px_4px_12px_rgba(0,0,0,0.06)]"
    x-show="mobileMenuOpen"
    style="display: none;"
    :aria-hidden="!mobileMenuOpen"
  >
    {
      headerNavigation.map((item) => (
        <a href={item.path} class={getNavLinkClasses(item.path, "mobile")}>
          {item.title}
        </a>
      ))
    }
    <div class="ml-4 p-16 text-gray-800">
      Kontakt:{" "}
      <a href={ZFL_EMAIL.url}>{ZFL_EMAIL.display}</a>
    </div>
  </nav>
  <noscript>
    <div class="bg-yellow-200">
      <div class="breakout-grid py-4">
        <p>
          <strong>Menü funktioniert nicht?</strong> Erlauben Sie JavaScript in den
          Browsereinstellungen oder navigieren Sie über den <a href="#footer"
            >Footer</a
          >.
        </p>
      </div>
    </div>
  </noscript>
</header>
