---
import { Icon } from "astro-icon/components";
import Card, { cardStyles } from "@/components/Card.astro";
import type { VariantProps } from "tailwind-variants";
import { ZFL_EMAIL, ZFL_PHONE } from "@/config/constants";

type Props = VariantProps<typeof cardStyles>;

const { look } = Astro.props;
---

<Card look={look}
  ><Icon name="ic:twotone-phone-enabled" class="-scale-x-100" slot="icon" />
  <h3>Kontaktieren Sie uns</h3>
  <div class="space-y-8">
    <p>
      Wir unterstützen Sie gerne persönlich in allen Phasen der Regelungsarbeit.
    </p>
    <p>
      Telefon: <a href={ZFL_PHONE.url}>{ZFL_PHONE.display}</a>
    </p>
    <p>
      E-Mail: <a href={ZFL_EMAIL.url}>{ZFL_EMAIL.display}</a>
    </p>
  </div>
</Card>
