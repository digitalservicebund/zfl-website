<script>
  import posthog from "posthog-js";
  import { getInstanceManager } from "@pagefind/component-ui";
  import type { PagefindSearchResult } from "@pagefind/component-ui";

  function debounce<TArgs extends unknown[]>(
    func: (...args: TArgs) => void,
    delay: number,
  ) {
    let timeoutId: ReturnType<typeof setTimeout>;
    return (...args: TArgs) => {
      clearTimeout(timeoutId);
      timeoutId = setTimeout(() => func(...args), delay);
    };
  }

  let term = "";

  const trackSearch = debounce((value: string, results: number) => {
    const query = value.trim();
    if (query.length > 3) {
      posthog.capture("search_input", { query, results });
    }
  }, 1000);

  const instance = getInstanceManager().getInstance("default");
  instance.on("search", (query) => {
    term = query as string;
  });
  instance.on("results", (result) => {
    const results = (result as PagefindSearchResult).results;
    trackSearch(term, results.length);
  });
</script>
