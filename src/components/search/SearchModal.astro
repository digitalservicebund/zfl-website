---
import PagefindConfig from "astro-pagefind/components/PagefindConfig.astro";
import SearchTracking from "./SearchTracking.astro";
import { isProduction } from "@/config/stage";
---

<>
  <PagefindConfig highlight-param="highlight" />
  <pagefind-modal>
    <pagefind-modal-header>
      <pagefind-input></pagefind-input>
    </pagefind-modal-header>
    <pagefind-modal-body>
      <search-modal-summary></search-modal-summary>
      <pagefind-results hide-sub-results></pagefind-results>
    </pagefind-modal-body>
    <pagefind-modal-footer>
      <pagefind-keyboard-hints></pagefind-keyboard-hints>
    </pagefind-modal-footer>
  </pagefind-modal>
  {isProduction && <SearchTracking />}
</>

<script src="./SearchModalSummary.ts"></script>

<script
  is:inline
  type="module"
  define:vars={{ baseUrl: import.meta.env.BASE_URL }}
>
  // change event to "astro:page-load" if using Astro's ClientRouter
  document.addEventListener("DOMContentLoaded", async () => {
    const base = baseUrl === "/" ? "" : baseUrl;
    await import(`${base}/pagefind/pagefind-highlight.js`);
    new PagefindHighlight({ highlightParam: "highlight" });
    const firstMatch = document.querySelector("mark.pagefind-highlight");
    firstMatch?.scrollIntoView({ behavior: "smooth", block: "center" });
  });
</script>

<style is:global>
  /* https://pagefind.app/docs/css-variables/ */

  :root {
    /* Colors — kern semantic tokens are compiled away by Lightning CSS,
       so we use the resolved primitive values directly */
    --pf-text: oklch(20.23% 0.0321 277.67); /* kern-color-neutral-950 */
    --pf-text-secondary: oklch(
      46.61% 0.0574 276.44
    ); /* kern-color-neutral-650 */
    --pf-text-muted: oklch(46.61% 0.0574 276.44); /* kern-color-neutral-650 */
    --pf-border: var(--kern-color-decorative-border-contextual, #c0c3d5);
    --pf-outline-focus: var(--color-cosmic-blue-base);
    --pf-mark: oklch(20.23% 0.0321 277.67); /* kern-color-neutral-950 */
    --pf-skeleton: var(--color-lavender-200);

    /* Typography */
    --pf-font:
      "Fira Sans", sans-serif; /* kern-typography-font-family-fira-sans */

    /* Sizing */
    --pf-input-font-size: 1.125rem; /* kern-typography-font-size-medium-static */
    --pf-input-height: 43px;
    --pf-result-title-font-size: 1.125rem; /* kern-typography-font-size-medium-static */
    --pf-result-excerpt-font-size: 1rem; /* kern-typography-font-size-small-static */
    --pf-results-gap: 1rem; /* kern-metric-space-default / kern-16 */
    --pf-summary-font-size: 1rem; /* kern-typography-font-size-small-static */

    /* Results layout */
    --pf-border-radius: 0.25rem; /* kern-metric-border-radius-default / kern-4 */

    /* Modal */
    --pf-modal-max-width: 720px;
  }

  :is(*, #\#):is(*, #\#) :is([class^="pf-"]) {
    -webkit-font-smoothing: antialiased;
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) dialog.pf-modal {
    border-radius: 0.5rem; /* kern-metric-border-radius-large / kern-8 */
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-trigger-text {
    font-size: 1.125rem; /* kern-typography-font-size-medium-static */
    font-family:
      "Fira Sans", sans-serif; /* kern-typography-font-family-fira-sans */
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-result-excerpt {
    white-space: normal;
    mark {
      background-color: oklch(93.09% 0.0428 170.49)
        /* kern-color-turquois-050 */;
    }
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-keyboard-hint,
  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-input-clear,
  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-keyboard-key {
    font-size: 1rem; /* kern-typography-font-size-small-static */
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-keyboard-key {
    height: 24px;
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-modal-footer {
    padding: 1rem; /* kern-metric-space-default */
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-modal-body .pf-summary {
    margin: 0.5rem 0; /* kern-metric-space-small */
  }

  :is(*, #\#):is(*, #\#):is(*, #\#) .pf-error {
    display: none; /* using custom error messages in SearchModalSummary.ts */
  }

  mark.pagefind-highlight {
    background-color: oklch(93.09% 0.0428 170.49) /* kern-color-turquois-050 */;
  }
</style>
