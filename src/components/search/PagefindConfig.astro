---
import "@pagefind/component-ui/css/pagefind-component-ui.css";
import { join } from "node:path/posix";

interface Props {
  instance?: string;
  filterTypes?: string[]; // for any-filter on pageType
}

const { instance, filterTypes, ...props } = Astro.props;
const bundlePath = join(import.meta.env.BASE_URL, "pagefind/");
---

<custom-pagefind-config
  {...props}
  instance={instance}
  data-bundle-path={bundlePath}
  data-filter-types={filterTypes?.join(".") || ""}
>
</custom-pagefind-config>

<script>
  import { getInstanceManager } from "@pagefind/component-ui";

  class CustomPagefindConfig extends HTMLElement {
    connectedCallback() {
      const instanceName = this.getAttribute("instance") || "default";
      const instance = getInstanceManager().getInstance(instanceName);

      instance.options.bundlePath =
        this.dataset.bundlePath || instance.options.bundlePath;
      instance.pagefindOptions.highlightParam = "search";
      instance.pagefindOptions.excerptLength = 20;

      // @ts-expect-error : instance._userTranslations is private, but the offical API intance.setTranslations is broken
      instance._userTranslations = { keyboard_clear: "schließen" }; // Esc always closes the modal
      instance.searchFilters = this.dataset.filterTypes
        ? {
            pageType: {
              // @ts-expect-error : instance.searchFilters type doesn't know "any" operator
              any: this.dataset.filterTypes.split("."),
            },
          }
        : {};
    }
  }
  if (!customElements.get("custom-pagefind-config")) {
    customElements.define("custom-pagefind-config", CustomPagefindConfig);
  }
</script>
