---
import Hero from "@/components/Hero.astro";
import Layout from "@/layouts/Layout.astro";
import { werkzeugfinder } from "@/config/routes";
import {
  getAllObjects,
  getAllReasons,
  getAllRessorts,
} from "@/data/werkzeugfinder";

export const frontmatter = {
  title: "Werkzeugfinder für Visualisierungen",
};

const ressorts = getAllRessorts();
const objects = getAllObjects();
const reasons = getAllReasons();

const empfehlungBase = `${werkzeugfinder.path}/empfehlung`;
---

<Layout title={frontmatter.title}>
  <main class="breakout-grid">
    <Hero>
      <h1>Werkzeugfinder für Visualisierungen</h1>
      <p slot="subtitle">
        Beantworten Sie uns drei Fragen und wir schlagen Ihnen das für Ihren
        Anlass passende Werkzeug vor.
      </p>
    </Hero>

    <section
      x-data={`{
        ressort: '',
        object: '',
        reason: '',
        errors: {},
        submit() {
          this.errors = {};
          if (!this.ressort) this.errors.ressort = 'Bitte wählen Sie ein Ressort aus.';
          if (!this.object) this.errors.object = 'Bitte wählen Sie eine Option aus.';
          if (!this.reason) this.errors.reason = 'Bitte wählen Sie einen Grund aus.';
          if (Object.keys(this.errors).length > 0) return;
          window.location.href = '${empfehlungBase}/' + this.ressort + '/' + this.object + '?reason=' + this.reason;
        }
      }`}
    >
      <div class="quiz-question border-lavender-400 pb-md mb-md border-b">
        <p class="kern-preline">1 von 3</p>
        <h2 class="mt-0">In welchem Ressort arbeiten Sie?</h2>
        <p>
          Diese Information benötigen wir, um in Ihrem Haus verfügbare Werkzeuge
          zu finden.
        </p>
        <div
          class="kern-form-input mt-sm"
          :class="{ 'kern-form-input--error': errors.ressort }"
        >
          <label class="kern-label" for="ressort-select">Ressort</label>
          <div class="kern-form-input__select-wrapper max-w-a11y">
            <select
              id="ressort-select"
              name="ressort"
              x-model="ressort"
              class="kern-form-input__select"
              :class="{ 'kern-form-input__select--error': errors.ressort }"
              aria-describedby="ressort-error"
            >
              <option value="">Bitte auswählen</option>
              {ressorts.map((r) => <option value={r.id}>{r.name}</option>)}
            </select>
          </div>
          <p
            id="ressort-error"
            class="kern-error"
            x-show="errors.ressort"
            role="alert"
          >
            <span
              class="kern-icon kern-icon--danger kern-icon--md"
              aria-hidden="true"></span>
            <span class="kern-body" x-text="errors.ressort"></span>
          </p>
        </div>
      </div>

      <div class="quiz-question border-lavender-400 pb-md mb-md border-b">
        <p class="kern-preline">2 von 3</p>
        <h2 class="mt-0">Was möchten Sie darstellen?</h2>
        <p>
          Die Art der Darstellung gibt vor, welches Werkzeug am besten passt.
        </p>
        <fieldset class="kern-fieldset mt-sm" aria-describedby="object-error">
          <legend class="sr-only">Was möchten Sie darstellen?</legend>
          <div class="kern-fieldset__body">
            {
              objects.map((obj) => (
                <div class="kern-form-check">
                  <input
                    class="kern-form-check__radio"
                    id={obj.id}
                    type="radio"
                    name="object"
                    value={obj.id}
                    x-model="object"
                  />
                  <label class="kern-label" for={obj.id}>
                    {obj.name}
                    {obj.description && (
                      <span class="max-w-a11y block text-gray-500!">
                        {obj.description}
                      </span>
                    )}
                  </label>
                </div>
              ))
            }
          </div>
          <p
            id="object-error"
            class="kern-error"
            x-show="errors.object"
            role="alert"
          >
            <span
              class="kern-icon kern-icon--danger kern-icon--md"
              aria-hidden="true"></span>
            <span class="kern-body" x-text="errors.object"></span>
          </p>
        </fieldset>
      </div>

      <div class="quiz-question pb-md mb-md">
        <p class="kern-preline">3 von 3</p>
        <h2 class="mt-0">Wofür möchten Sie die Visualisierung erstellen?</h2>
        <p>Bei mehreren Gründen nennen Sie uns den wichtigsten.</p>
        <fieldset class="kern-fieldset mt-sm" aria-describedby="reason-error">
          <legend class="sr-only"
            >Wofür möchten Sie die Visualisierung erstellen?</legend
          >
          <div class="kern-fieldset__body">
            {
              reasons.map((r) => (
                <div class="kern-form-check">
                  <input
                    class="kern-form-check__radio"
                    id={r.id}
                    type="radio"
                    name="reason"
                    value={r.id}
                    x-model="reason"
                  />
                  <label class="kern-label" for={r.id}>
                    {r.name}
                    {r.description && (
                      <span class="max-w-a11y block text-gray-500!">
                        {r.description}
                      </span>
                    )}
                  </label>
                </div>
              ))
            }
          </div>
          <p
            id="reason-error"
            class="kern-error"
            x-show="errors.reason"
            role="alert"
          >
            <span
              class="kern-icon kern-icon--danger kern-icon--md"
              aria-hidden="true"></span>
            <span class="kern-body" x-text="errors.reason"></span>
          </p>
        </fieldset>
      </div>

      <div>
        <button
          type="button"
          @click="submit()"
          class="kern-btn kern-btn--primary"
        >
          Werkzeug suchen
        </button>
      </div>
    </section>
  </main>
</Layout>
