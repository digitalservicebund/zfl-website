---
import Hero from "@/components/Hero.astro";
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/Card.astro";
import { routes } from "@/config/routes";
import { Image } from "astro:assets";
import {
  findResultByObjectAndRessort,
  getAllObjectIds,
  getAllRessortIds,
  getObjectById,
  getReasonById,
  getRessortById,
} from "@/data/werkzeugfinder";

export function getStaticPaths() {
  const ressortIds = getAllRessortIds();
  const objectIds = getAllObjectIds();
  return ressortIds.flatMap((ressort) =>
    objectIds.map((object) => ({ params: { ressort, object } })),
  );
}

const { ressort: ressortId, object: objectId } = Astro.params;

const ressort = getRessortById(ressortId);
const object = getObjectById(objectId);
const result = findResultByObjectAndRessort(objectId, ressortId);

const quizPath = routes.werkzeugfinder.path;
---

<Layout title="Empfohlenes Werkzeug – Werkzeugfinder">
  <main class="breakout-grid">
    <Hero>
      <h1>Empfohlenes Werkzeug</h1>
    </Hero>

    {
      result ? (
        <>
          <section>
            <div class="border-lavender-400 overflow-hidden rounded-sm border-4">
              <Image
                src={result.cluster.img.src}
                alt={result.cluster.img.alt}
                class="w-full"
              />
              <div class="p-md">
                <p class="kern-preline mb-4">
                  Wir empfehlen Ihnen eine Visualisierung als:
                </p>
                <h2 class="mt-0 kern-title kern-title--large">{result.cluster.name}</h2>
                <p>{result.cluster.description}</p>
                <a
                  href={`${routes.werkzeugfinder.path}/${result.cluster.id}`}
                  class="kern-btn kern-btn--primary"
                >
                  {result.cluster.name} Anleitung
                </a>

                <div class="mt-lg divide-lavender-400 border-lavender-400 divide-y rounded-sm border">
                  {result.recommendations.map((rec) => (
                    <div class="p-md">
                      <p class="kern-preline kern-preline--small mb-4 text-gray-900">
                        {rec.fidelity.name}
                      </p>
                      <h3 class="mt-0 kern-title">{rec.primaryTool.name}</h3>
                      <div class="gap-md flex flex-col sm:flex-row">
                        <div class="flex-1">
                          <p>{rec.primaryTool.description}</p>
                          {rec.primaryTool.link && (
                            <a
                              href={rec.primaryTool.link}
                              class="whitespace-pre-line"
                            >
                              {rec.primaryTool.link}
                            </a>
                          )}
                          {rec.primaryTool.access && (
                            <p class="bg-lavender-200 p-sm! rounded-sm kern-body kern-body--small">
                              <strong>Zugang: </strong>
                              {rec.primaryTool.access}
                            </p>
                          )}
                        </div>
                        {(rec.primaryTool.img ||
                          rec.alternativeTools.length > 0) && (
                          <div class="space-y-md flex-1">
                            {rec.primaryTool.img && (
                              <Image
                                src={rec.primaryTool.img.src}
                                alt={rec.primaryTool.img.alt}
                                class="border-lavender-400 w-full rounded-sm border"
                              />
                            )}
                            {rec.alternativeTools.length > 0 && (
                              <div class="bg-lavender-200 p-sm rounded-sm">
                                <h4 class="mt-0">Alternativen</h4>
                                <p>
                                  Wenn Sie {rec.primaryTool.name} nicht nutzen
                                  können oder möchten, können Sie ein{" "}
                                  {result.cluster.name} auch in folgenden
                                  Anwendungen erstellen:
                                </p>
                                <ul>
                                  {rec.alternativeTools.map((alt) => (
                                    <li>{alt.name}</li>
                                  ))}
                                </ul>
                              </div>
                            )}
                          </div>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </section>

          <section
            x-data="{ reasonName: '' }"
            x-init={`
              const params = new URLSearchParams(window.location.search);
              const reasonId = params.get('reason');
              const reasonMap = ${JSON.stringify(
                Object.fromEntries(
                  [
                    "austausch",
                    "selbst",
                    "dokumentation",
                    "unbekannt",
                    "anderes",
                  ].map((id) => [id, getReasonById(id)?.name ?? id]),
                ),
              )};
              reasonName = reasonId ? (reasonMap[reasonId] || reasonId) : '';
            `}
          >
            <Card look="lavender">
              <h3 class="mt-0">Ihre Auswahl</h3>
              <ul>
                <li>
                  Ressort: <strong>{ressort?.name ?? ressortId}</strong>
                </li>
                <li>
                  Objekt der Darstellung:{" "}
                  <strong>{object?.name ?? objectId}</strong>
                </li>
                <li x-show="reasonName">
                  Grund der Visualisierung: <strong x-text="reasonName" />
                </li>
              </ul>
              <p>
                <a class="kern-btn kern-btn--primary" href={quizPath}>
                  Eingaben ändern
                </a>
              </p>
            </Card>
          </section>
        </>
      ) : (
        <section>
          <h2>Es ist ein Fehler aufgetreten.</h2>
          <p>
            Es tut uns Leid! Aus unbekannten Gründen ist ein Fehler aufgetreten.
            Bitte versuchen Sie es erneut.
          </p>
          <a href={quizPath} class="kern-btn kern-btn--primary">
            Zurück
          </a>
        </section>
      )
    }
  </main>
</Layout>
