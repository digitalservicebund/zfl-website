---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero.astro";
import RegelungsprozessFlowWithMinimap from "./_RegelungsprozessFlowWithMinimap.svelte";

export const frontmatter = {
  title: "Svelte",
  isStagingOnly: true,
};
---

<Layout title={frontmatter.title}>
  <main class="breakout-grid">
    <Hero>
      <h1>{frontmatter.title}</h1>
    </Hero>

    <div class="my-lg">
      <RegelungsprozessFlowWithMinimap client:load />
    </div>
  </main>
</Layout>
