---
import { allRoutes, vorhaben_fruephase2 } from "@/config/routes";
import FormStepLayout from "../_components/FormStepLayout.astro";
import ButtonBar from "../_components/ButtonBar.astro";
import MenuExtension from "./_components/MenuExtension.astro";

type Props = {
  title: string;
  pageNumber: number;
  isWide?: boolean;
  openModal?: boolean;
};

const { title, pageNumber, isWide, openModal } = Astro.props;

const stepRoutes = allRoutes
  .filter(
    (r): r is (typeof allRoutes)[number] & { navOrder: number } =>
      r.parent === vorhaben_fruephase2 && r.navOrder !== null,
  )
  .sort((a, b) => a.navOrder - b.navOrder);
const prevPath = stepRoutes.findLast((r) => r.navOrder < pageNumber)?.path;
const nextPath = stepRoutes.find((r) => r.navOrder > pageNumber)?.path;
---

<FormStepLayout
  title={title}
  pageNumber={pageNumber}
  totalPages={stepRoutes.length}
  isWide={isWide}
>
  <MenuExtension
    slot="section-sidebar-extra"
    pageNumber={pageNumber}
    totalPages={stepRoutes.length}
  />
  <slot />
  {
    Astro.slots.has("button-bar") && (
      <slot name="button-bar" slot="button-bar" />
    )
  }
  {
    !Astro.slots.has("button-bar") && (
      <ButtonBar
        slot="button-bar"
        prevPath={prevPath}
        nextPath={nextPath}
        openModal={openModal}
      />
    )
  }
</FormStepLayout>
