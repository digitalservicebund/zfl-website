---
import FruephaseLayout from "./_FruephaseLayout.astro";
import KernTable from "../_components/KernTable.astro";
import KernTableCell from "../_components/KernTableCell.astro";
import KernTableHeaderCell from "../_components/KernTableHeaderCell.astro";
import KernTableRow from "../_components/KernTableRow.astro";

export const frontmatter = {
  title: "Entwicklung von Handlungsalternativen",
  navLabel: "9. Entwicklung von Handlungsalternativen",
  sitemap: false,
  navOrder: 5,
};
---

<FruephaseLayout title={frontmatter.title} pageNumber={frontmatter.navOrder}>
  <h2>{frontmatter.navLabel}</h2>
  <div>
    <div class="columns-2">
      <p class="p-20">
        Entwerfen Sie Ideen für Handlungsalternativen, nutzen Sie hierfür die
        Ursachen- und Wirkungsketten aus der <a
          href="https://google.de"
          target="_blank">Problemanalyse</a
        > und/oder ziehen Sie ggf. Expertinnen und Experten hinzu.
      </p>
      <div class="break-inside-avoid">
        <div class="rounded-xl bg-blue-100 p-20">
          <p>
            <b>Tipp</b>
          </p>
          Denken Sie weit! Entwickeln Sie dabei zum Beispiel Lösungsoptionen für Anreize
          und Förderungen sowie für Verbote und Sanktionen. Berücksichtigen Sie dabei
          auch die Möglichkeiten aus dem Regulatorischen Instrumentenkasten.
        </div>
      </div>
    </div>
    <h3>So geht es</h3>
    <ol>
      <li>
        Sammeln Sie so viele Handlungsalternativen, wie möglich. Vorschlag:
        Nutzen Sie dazu die <a href="https://google.de" target="_blank"
          >Brainwriting-Methode</a
        >. Masse statt klasse. Streben Sie auch nicht-regulatorische
        Alternativen an.
      </li>
      <li>Erstellen Sie eine Liste.</li>
      <li>
        Suchen Sie 2–3 Handlungsalternativen aus, die einen besonderen Nutzen im
        Verhältnis zum Aufwand erwarten lassen.
      </li>
      <li>
        Beantworten Sie zunächst den Status Quo und inwiefern dieser die
        Indikatoren jeweils erfüllt.
      </li>
      <li>
        Beantworten Sie dann pro Handlungsalternative, inwiefern der Indikator
        erfüllt wird: Ja, nein, unklar. Sie können Texte dazuschreiben
      </li>
    </ol>
  </div>

  <div
    x-data="handlungsAlternativenTable"
    class="relative left-1/2 w-[calc(100vw-32px)] max-w-7xl -translate-x-1/2"
  >
    <KernTable columnCount={5}>
      <Fragment slot="caption">Handlungsalternativen Tabelle</Fragment>
      <Fragment slot="header">
        <KernTableHeaderCell />
        <KernTableHeaderCell>Wirkziele</KernTableHeaderCell>
        <KernTableHeaderCell>Indikatoren</KernTableHeaderCell>
        <KernTableHeaderCell>Status Quo</KernTableHeaderCell>
        <KernTableHeaderCell>Handlungsalternativen</KernTableHeaderCell>
      </Fragment>
      <Fragment slot="body">
        <KernTableRow>
          <KernTableCell>-</KernTableCell>
          <KernTableCell>
            <b>Beispiel Vollautomatisiertes Fahren:</b>
            Fahrzeugautomatisierungstechnologie kann (rechts-)sicher im deutschen
            Verkehr eingesetzt werden.
          </KernTableCell>
          <KernTableCell>
            Versicherer bieten KfZ-Pflichtversicherungen für h/v Fahrzeuge ohne
            (Risiko-)Aufschläge an.
          </KernTableCell>
          <KernTableCell />
        </KernTableRow>

        <template x-for="(row, index) in rows" :key="index">
          <KernTableRow>
            <KernTableCell>
              <!-- <button type="button" @click="deleteRow(index)">
                <span
                  class="kern-icon kern-icon--delete kern-icon--default"
                  aria-hidden="true"></span>
              </button> -->
              <p>index</p>
            </KernTableCell>
            <KernTableCell>
              <p x-text="row.wirkziel"></p>
            </KernTableCell>
            <KernTableCell>
              <p x-text="row.indikatoren"></p>
            </KernTableCell>
            <KernTableCell>
              <div class="kern-form-input">
                <input
                  class="kern-form-input__input w-full"
                  :id="`status-quo-${index}`"
                  :name="`status-quo-${index}`"
                  type="text"
                  aria-label="Status Quo"
                  x-model="row.statusQuo"
                />
              </div>
            </KernTableCell>
            <KernTableCell>
              <div class="kern-form-input">
                <input
                  class="kern-form-input__input w-full"
                  :id="`handlungsalternativen-${index}`"
                  :name="`handlungsalternativen-${index}`"
                  type="text"
                  aria-label="Handlungsalternativen"
                  x-model="row.handlungsalternativen"
                />
              </div>
            </KernTableCell>
          </KernTableRow>
        </template>
      </Fragment>
    </KernTable>
  </div>
</FruephaseLayout>

<script>
  import Alpine from "alpinejs";
  import { registerDynamicTable } from "../_components/kernTableState";

  type WirkkonzeptRow = {
    wirkziel: string;
    indikatoren: string;
    erfolgsschwelle: string;
    datengrundlage: string;
    statusQuo: string;
    handlungsalternativen: string[];
  };

  const getInitialRowsFromWirkkonzept = (): WirkkonzeptRow[] => {
    try {
      const raw = localStorage.getItem("wirkkonzept");
      if (!raw) {
        return [
          {
            wirkziel: "",
            indikatoren: "",
            erfolgsschwelle: "",
            datengrundlage: "",
            statusQuo: "",
            handlungsalternativen: [],
          },
        ];
      }

      const parsed: WirkkonzeptRow[] = JSON.parse(raw);
      return parsed.length > 0
        ? parsed
        : [
            {
              wirkziel: "",
              indikatoren: "",
              erfolgsschwelle: "",
              datengrundlage: "",
              statusQuo: "",
              handlungsalternativen: [],
            },
          ];
    } catch {
      return [
        {
          wirkziel: "",
          indikatoren: "",
          erfolgsschwelle: "",
          datengrundlage: "",
          statusQuo: "",
          handlungsalternativen: [],
        },
      ];
    }
  };

  registerDynamicTable(
    "handlungsAlternativenTable",
    () => ({
      wirkziel: "",
      indikatoren: "",
      erfolgsschwelle: "",
      datengrundlage: "",
      statusQuo: "",
      handlungsalternativen: [] as string[],
    }),
    getInitialRowsFromWirkkonzept(),
    "wirkkonzept",
  );

  document.addEventListener("DOMContentLoaded", () => {
    document
      .querySelectorAll<HTMLAnchorElement>("#Weiter, #Zurück")
      .forEach((link) => {
        link.addEventListener("click", () => {
          const el = document.querySelector<HTMLElement>(
            "[x-data='handlungsAlternativenTable']",
          );
          if (el) {
            (
              Alpine.$data(el) as { saveToStorage?: () => void }
            ).saveToStorage?.();
          }
        });
      });
  });
</script>
