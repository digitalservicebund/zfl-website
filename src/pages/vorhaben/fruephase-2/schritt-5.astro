---
import FruephaseLayout from "./_FruephaseLayout.astro";
import KernTable from "../_components/KernTable.astro";
import KernTableCell from "../_components/KernTableCell.astro";
import KernTableHeaderCell from "../_components/KernTableHeaderCell.astro";
import KernTableRow from "../_components/KernTableRow.astro";

export const frontmatter = {
  title: "9. Handlungsalternativen entwickeln",
  navLabel: "9. Handlungsalternativen entwickeln",
  sitemap: false,
  navOrder: 5,
};
---

<FruephaseLayout title={frontmatter.title} pageNumber={frontmatter.navOrder}>
  <h2>{frontmatter.title}</h2>
  <div>
    <div class="columns-2">
      <p class="p-20">
        Entwerfen Sie Ideen für Handlungsalternativen, nutzen Sie hierfür die
        Ursachen- und Wirkungsketten aus der <a
          href="https://google.de"
          target="_blank">Problemanalyse</a
        > und/oder ziehen Sie ggf. Expertinnen und Experten hinzu.
      </p>
      <div class="break-inside-avoid">
        <div class="rounded-xl bg-blue-100 p-20">
          <p>
            <b>Tipp</b>
          </p>
          Denken Sie weit! Entwickeln Sie dabei zum Beispiel Lösungsoptionen für Anreize
          und Förderungen sowie für Verbote und Sanktionen. Berücksichtigen Sie dabei
          auch die Möglichkeiten aus dem Regulatorischen Instrumentenkasten.
        </div>
      </div>
    </div>
    <h3>So geht es</h3>
    <ol>
      <li>
        Sammeln Sie so viele Handlungsalternativen, wie möglich. Vorschlag:
        Nutzen Sie dazu die <a href="https://google.de" target="_blank"
          >Brainwriting-Methode</a
        >. Masse statt klasse. Streben Sie auch nicht-regulatorische
        Alternativen an.
      </li>
      <li>Erstellen Sie eine Liste.</li>
      <li>
        Suchen Sie 2–3 Handlungsalternativen aus, die einen besonderen Nutzen im
        Verhältnis zum Aufwand erwarten lassen.
      </li>
      <li>
        Beantworten Sie zunächst den Status Quo und inwiefern dieser die
        Indikatoren jeweils erfüllt.
      </li>
      <li>
        Beantworten Sie dann pro Handlungsalternative, inwiefern der Indikator
        erfüllt wird: Ja, nein, unklar. Sie können Texte dazuschreiben
      </li>
    </ol>
  </div>

  <div
    x-data="handlungsAlternativenTable"
    class="relative left-1/2 w-[calc(100vw-32px)] max-w-7xl -translate-x-1/2 min-[900px]:w-[calc(100vw-300px-32px)]"
  >
    <KernTable columnCount={5}>
      <Fragment slot="caption">Handlungsalternativen Tabelle</Fragment>
      <Fragment slot="header">
        <KernTableHeaderCell />
        <KernTableHeaderCell>Wirkziele</KernTableHeaderCell>
        <KernTableHeaderCell>Indikatoren</KernTableHeaderCell>
        <KernTableHeaderCell>Status Quo</KernTableHeaderCell>
        <template
          x-for="(_, altIndex) in (rows[0]?.handlungsalternativen ?? [])"
          :key="`handlungsalternativen-header-${altIndex}`"
        >
          <KernTableHeaderCell>
            <p x-text="`Handlungsalternative ${altIndex + 1}`"></p>
          </KernTableHeaderCell>
        </template>
        <KernTableHeaderCell />
      </Fragment>
      <Fragment slot="body">
        <KernTableRow>
          <KernTableCell>-</KernTableCell>
          <KernTableCell>
            <b>Beispiel Vollautomatisiertes Fahren:</b>
            Fahrzeugautomatisierungstechnologie kann (rechts-)sicher im deutschen
            Verkehr eingesetzt werden.
          </KernTableCell>
          <KernTableCell>
            Versicherer bieten KfZ-Pflichtversicherungen für h/v Fahrzeuge ohne
            (Risiko-)Aufschläge an.
          </KernTableCell>
          <KernTableCell />
          <template
            x-for="(_, altIndex) in (rows[0]?.handlungsalternativen ?? [])"
            :key="`beispiel-handlungsalternativen-${altIndex}`"
          >
            <KernTableCell />
          </template>
          <KernTableCell :rowspan="rows.length + 1" class="p-0 align-middle">
            <button
              type="button"
              class="flex h-full w-full items-center justify-center gap-4 px-16 py-8 text-center"
              @click="rows.forEach((currentRow) => currentRow.handlungsalternativen.push(''))"
            >
              <span
                class="kern-icon kern-icon--add kern-icon--default"
                aria-hidden="true"></span>
              Handlungsalternative hinzufügen
            </button>
          </KernTableCell>
        </KernTableRow>

        <template x-for="(row, index) in rows" :key="index">
          <template x-if="!row.isHeaderRow">
            <KernTableRow>
              <KernTableCell>
                <p
                  x-text="index + 1 - (rows.slice(0, index).filter(r => r.isHeaderRow).length)"
                >
                </p>
              </KernTableCell>
              <KernTableCell>
                <p x-text="row.wirkziel"></p>
              </KernTableCell>
              <KernTableCell>
                <p x-text="row.indikatoren"></p>
              </KernTableCell>
              <KernTableCell>
                <div class="kern-form-input">
                  <input
                    class="kern-form-input__input w-full"
                    :id="`status-quo-${index}`"
                    :name="`status-quo-${index}`"
                    type="text"
                    aria-label="Status Quo"
                    x-model="row.statusQuo"
                  />
                </div>
              </KernTableCell>
              <template
                x-for="(_, alternativeIndex) in row.handlungsalternativen"
                :key="`handlungsalternativen-${index}-${alternativeIndex}`"
              >
                <KernTableCell>
                  <div class="kern-form-input">
                    <input
                      class="kern-form-input__input w-full"
                      :id="`handlungsalternativen-${index}-${alternativeIndex}`"
                      :name="`handlungsalternativen-${index}-${alternativeIndex}`"
                      type="text"
                      :aria-label="`Handlungsalternative ${alternativeIndex + 1}`"
                      x-model="row.handlungsalternativen[alternativeIndex]"
                    />
                  </div>
                </KernTableCell>
              </template>
            </KernTableRow>
          </template>
        </template>
      </Fragment>
    </KernTable>
  </div>

  <script>
    import Alpine from "alpinejs";
    import { registerDynamicTable } from "../_components/kernTableState";

    type WirkkonzeptRow = {
      wirkziel: string;
      indikatoren: string;
      erfolgsschwelle: string;
      datengrundlage: string;
      statusQuo: string;
      handlungsalternativen: string[];
      isHeaderRow?: boolean;
    };

    const REQUIRED_WIRKZIELE = [
      "Digitaltauglichkeit",
      "Vollzugstauglichkeit",
      "Praxistauglichkeit",
      "Bürgerfreundlichkeit",
    ];
    const REQUIRED_WIRKZIELE_SET = new Set(
      REQUIRED_WIRKZIELE.map((wirkziel) => wirkziel.toLocaleLowerCase()),
    );

    const createDefaultRow = (wirkziel: string): WirkkonzeptRow => ({
      wirkziel,
      indikatoren: "",
      erfolgsschwelle: "",
      datengrundlage: "",
      statusQuo: "",
      handlungsalternativen: [""],
    });

    const normalizeRow = (row: WirkkonzeptRow): WirkkonzeptRow => {
      if (Array.isArray(row.handlungsalternativen)) {
        return {
          ...row,
          handlungsalternativen:
            row.handlungsalternativen.length > 0
              ? row.handlungsalternativen
              : [""],
        };
      }

      if (typeof row.handlungsalternativen === "string") {
        return {
          ...row,
          handlungsalternativen: [row.handlungsalternativen],
        };
      }

      return {
        ...row,
        handlungsalternativen: [""],
      };
    };

    const normalizeWirkzielKey = (wirkziel: string): string =>
      wirkziel.trim().toLocaleLowerCase();

    const getCustomWirkzieleRows = (): WirkkonzeptRow[] => {
      try {
        const raw = localStorage.getItem("wirkkonzept");
        if (!raw) {
          return [];
        }

        const parsed: WirkkonzeptRow[] = JSON.parse(raw);
        return parsed.filter((row) => {
          const wirkziel = row.wirkziel.trim();
          return (
            wirkziel.length > 0 &&
            !REQUIRED_WIRKZIELE_SET.has(wirkziel.toLocaleLowerCase())
          );
        });
      } catch {
        return [];
      }
    };

    const mergeRowsWithLatestWirkziele = (
      existingRows: WirkkonzeptRow[],
    ): WirkkonzeptRow[] => {
      const normalizedExistingRows = existingRows.map(normalizeRow);
      const findExistingRow = (
        wirkziel: string,
      ): WirkkonzeptRow | undefined => {
        const key = normalizeWirkzielKey(wirkziel);
        return normalizedExistingRows.find(
          (row) => normalizeWirkzielKey(row.wirkziel) === key,
        );
      };

      const customRows = getCustomWirkzieleRows().map((sourceRow) => {
        const existingRow = findExistingRow(sourceRow.wirkziel);

        return normalizeRow({
          wirkziel: sourceRow.wirkziel,
          indikatoren: sourceRow.indikatoren,
          erfolgsschwelle: sourceRow.erfolgsschwelle,
          datengrundlage: sourceRow.datengrundlage,
          statusQuo: existingRow?.statusQuo ?? "",
          handlungsalternativen: existingRow?.handlungsalternativen ?? [""],
        });
      });

      const defaultRows = REQUIRED_WIRKZIELE.map((wirkziel) => {
        const existingRow = findExistingRow(wirkziel);
        return existingRow
          ? normalizeRow({ ...existingRow, wirkziel })
          : createDefaultRow(wirkziel);
      });

      const headerRow: WirkkonzeptRow = {
        wirkziel: "",
        indikatoren: "",
        erfolgsschwelle: "",
        datengrundlage: "",
        statusQuo: "",
        handlungsalternativen: [],
        isHeaderRow: true,
      };

      return [...customRows, headerRow, ...defaultRows];
    };

    const getInitialRowsFromWirkkonzept = (): WirkkonzeptRow[] => {
      return mergeRowsWithLatestWirkziele([]);
    };

    registerDynamicTable(
      "handlungsAlternativenTable",
      () => ({
        wirkziel: "",
        indikatoren: "",
        erfolgsschwelle: "",
        datengrundlage: "",
        statusQuo: "",
        handlungsalternativen: [""] as string[],
      }),
      getInitialRowsFromWirkkonzept(),
      "handlungsalternativen",
    );

    document.addEventListener("DOMContentLoaded", () => {
      const tableElement = document.querySelector<HTMLElement>(
        "[x-data='handlungsAlternativenTable']",
      );
      if (tableElement) {
        const tableState = Alpine.$data(tableElement) as {
          rows?: WirkkonzeptRow[];
          saveToStorage?: () => void;
        };

        tableState.rows = mergeRowsWithLatestWirkziele(
          Array.isArray(tableState.rows) ? tableState.rows : [],
        );
        tableState.saveToStorage?.();
      }

      document
        .querySelectorAll<HTMLAnchorElement>("#Weiter, #Zurück")
        .forEach((link) => {
          link.addEventListener("click", () => {
            const el = document.querySelector<HTMLElement>(
              "[x-data='handlungsAlternativenTable']",
            );
            if (el) {
              (
                Alpine.$data(el) as { saveToStorage?: () => void }
              ).saveToStorage?.();
            }
          });
        });
    });
  </script>
</FruephaseLayout>
