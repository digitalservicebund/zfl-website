---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import {
  vorhaben_fruephase2_schritt2,
  vorhaben_fruephase2_schritt3,
  vorhaben_fruephase2_schritt4,
  vorhaben_fruephase2_schritt5,
  vorhaben_fruephase2_schritt6,
  vorhaben_fruephase2_schritt7,
} from "@/config/routes";

export const frontmatter = {
  title: "Vorhaben erarbeiten",
  sitemap: true,
  navLabel: "Ihr Vorhaben",
};

type TaskStatus = {
  variant: "success" | "info";
  label: string;
  showIcon: boolean;
  smallLabel: boolean;
};

type Task = {
  number: number;
  title: string;
  href?: string;
  status?: TaskStatus;
};

type Phase = {
  id?: string;
  title: string;
  tasks: Task[];
};

const phases: Phase[] = [
  {
    title: "Phase I: Synergien heben",
    tasks: [
      {
        number: 1,
        title: "Steckbrief erstellen",
        status: {
          variant: "success",
          label: "Erledigt",
          showIcon: true,
          smallLabel: false,
        },
      },
      {
        number: 2,
        title: "Mit der Leitungsebene abklären",
        status: {
          variant: "success",
          label: "Erledigt",
          showIcon: true,
          smallLabel: false,
        },
      },
      {
        number: 3,
        title: "Steckbrief versenden an andere Ressorts, ZfL, NKR-S und StaBA",
        status: {
          variant: "success",
          label: "Erledigt",
          showIcon: true,
          smallLabel: false,
        },
      },
      {
        number: 4,
        title: "Rückmeldungen sammeln",
        status: {
          variant: "success",
          label: "Erledigt",
          showIcon: true,
          smallLabel: false,
        },
      },
    ],
  },
  {
    id: "phase-2",
    title: "Phase II: Inhalte erarbeiten",
    tasks: [
      {
        number: 5,
        title: "Problem- und Lebenslagen analysieren",
        status: {
          variant: "success",
          label: "Erledigt",
          showIcon: true,
          smallLabel: false,
        },
      },
      {
        number: 6,
        title: "Betroffene einbeziehen",
        href: vorhaben_fruephase2_schritt2.path,
      },
      {
        number: 7,
        title: "Problem definieren",
        href: vorhaben_fruephase2_schritt3.path,
      },
      {
        number: 8,
        title: "Ziel definieren",
        href: vorhaben_fruephase2_schritt4.path,
      },
      {
        number: 9,
        title: "Handlungsalternativen entwickeln",
        href: vorhaben_fruephase2_schritt5.path,
      },
      {
        number: 10,
        title: "Handlungsalternative auswählen und testen",
        href: vorhaben_fruephase2_schritt6.path,
      },
      {
        number: 11,
        title: "Wirkkonzept fertigstellen",
        href: vorhaben_fruephase2_schritt7.path,
      },
    ],
  },
  {
    title: "Phase III: Regulierung umsetzen",
    tasks: [
      {
        number: 12,
        title: "Ggf. Referentenentwurf schreiben",
        status: {
          variant: "info",
          label: "Noch nicht zu bearbeiten",
          showIcon: false,
          smallLabel: true,
        },
      },
    ],
  },
];
---

<Layout title={frontmatter.title}>
  <main class="breakout-grid">
    <section class="mx-auto max-w-730">
      <h1>Vorhaben erarbeiten</h1>
      <p class="kern-body">
        Die neue Frühphase ersetzt den bisherigen Ablauf der Erarbeitung eines
        Referentenentwurfes. Sie besteht aus drei Phasen, in denen Sie Ihr
        Handlungsvorhaben inhaltlich definieren, Feedback einholen und die
        Regulierungsform entscheiden.
      </p>
      <div class="kern-task-list">
        {
          phases.map((phase) => (
            <>
              <div class="kern-task-list__header">
                <h2 id={phase.id} class="kern-heading-medium">
                  {phase.title}
                </h2>
              </div>

              <ul class="kern-task-list__list">
                {phase.tasks.map((task) => (
                  <li class="kern-task-list__item">
                    <span class="kern-number">{task.number}</span>
                    <div class="kern-task-list__title">
                      <p class="kern-body">
                        {task.href ? (
                          <a href={task.href}>{task.title}</a>
                        ) : (
                          task.title
                        )}
                      </p>
                      {task.status && (
                        <div class="kern-task-list__status">
                          <span
                            class={`kern-badge ${task.status.variant === "success" ? "kern-badge--success" : "kern-badge--info"}`}
                          >
                            {task.status.showIcon && (
                              <span
                                class="kern-icon kern-icon--success"
                                aria-hidden="true"
                              />
                            )}
                            <span
                              class={
                                task.status.smallLabel
                                  ? "kern-label kern-label--small"
                                  : "kern-label"
                              }
                            >
                              {task.status.label}
                            </span>
                          </span>
                        </div>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            </>
          ))
        }
      </div>

      <div
        class="kern-alert kern-alert--info mt-md border-cosmic-blue-base"
        role="alert"
      >
        <div class="kern-alert__header bg-cosmic-blue-100">
          <Icon
            name="ic:baseline-real-estate-agent"
            class="text-cosmic-blue-base h-24 w-24"
          />
          <span class="kern-title"
            >Integrierte Arbeitshilfen und Checks: 54</span
          >
        </div>
        <div class="kern-alert__body">
          <p class="kern-body">
            Nach und nach werden alle Arbeitshilfen und Checks in den 3 Phasen
            der Neuen Frühphase integriert.
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>
