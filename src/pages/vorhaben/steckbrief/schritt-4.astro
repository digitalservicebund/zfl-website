---
import SteckbriefWrapper from "./_components/SteckbriefWrapper.astro";
import SidebarTriggerButton from "./_components/SidebarTriggerButton.astro";
import Textarea from "./_components/Textarea.astro";
import Hint from "./_components/Hint.astro";

export const frontmatter = {
  title: "4. Vorläufige Zielsetzung",
  sitemap: false,
  navOrder: 4,
  navLabel: "4. Zielsetzung",
};

const zielHintId = "zielsetzung-hint";
---

<SteckbriefWrapper title={frontmatter.title} pageNumber={frontmatter.navOrder}>
  <div class="flex flex-col gap-16">
    <h2 class="mt-0">
      Vorläufige Zielsetzung
      <SidebarTriggerButton hintId={zielHintId} />
    </h2>
    <p>
      Definieren Sie den angestrebten Endzustand sowie den messbaren Nutzen, der
      durch dieses Vorhaben erreicht werden soll.
    </p>
  </div>
  <Textarea id="zielsetzung" label="Zielsetzung des Vorhabens" />
  <Hint slot="hint" id={zielHintId}>
    <h2 class="m-0 text-[21px] font-bold">Leitfragen zur Zielsetzung</h2>
    <ul class="m-0 list-disc pl-27 [&>li]:mb-8 [&>li:last-child]:mb-0">
      <li>
        Welche konkrete Verbesserung soll für Bürgerinnen und Bürger,
        Unternehmen oder Verwaltung erreicht werden?
      </li>
      <li>
        Welche unmittelbaren Ergebnisse sollen entstehen (z. B. neue Verfahren,
        klarere Vorgaben, vereinfachte Abläufe)?
      </li>
      <li>
        Welche Wirkungen bei den Betroffenen sollen eintreten (z. B. Entlastung,
        geringerer Aufwand, mehr Transparenz, höhere Rechtssicherheit)?
      </li>
      <li>
        Gibt es bereits eine klare Zielvorstellung – oder handelt es sich noch
        um eine erste, vorläufige Zielskizze?
      </li>
    </ul>
  </Hint>
</SteckbriefWrapper>
