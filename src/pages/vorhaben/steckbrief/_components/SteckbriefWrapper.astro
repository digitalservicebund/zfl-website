---
import { ClientRouter } from "astro:transitions";
import Layout from "@/layouts/Layout.astro";
import HintSidebar from "./HintSidebar.astro";
import ButtonBar from "./ButtonBar.astro";
import { vorhaben_steckbrief, allRoutes } from "@/config/routes";

type Props = {
  title: string;
  pageNumber: number;
  isWide?: boolean;
};
const { title, pageNumber, isWide } = Astro.props;

const stepRoutes = allRoutes.filter((r) => r.parent === vorhaben_steckbrief);
const totalPages = stepRoutes.length;
const prevPath = stepRoutes.find((r) => r.navOrder === pageNumber - 1)?.path;
const nextPath = stepRoutes.find((r) => r.navOrder === pageNumber + 1)?.path;
---

<Layout title={title} noFooter>
  <head>
    <ClientRouter />
  </head>
  <main>
    <div
      class="_gap-32 flex flex-1 flex-col lg:flex-row lg:items-stretch"
      x-data="{ hintId: '' }"
    >
      <div class="min-w-0 flex-1">
        <div
          class="py-lg mx-auto w-full max-w-(--max-width) px-16"
          style={{
            "--max-width": `${isWide ? 1280 : 736}px`,
          }}
        >
          <div class="kern-progress mb-lg">
            <label class="kern-label" for="progress1">
              Schritt {pageNumber} von {totalPages}
            </label>
            <progress id="progress1" value={pageNumber} max={totalPages}
            ></progress>
          </div>
          <h1 class="sr-only">Steckbrief: {title}</h1>
          <form class="flex flex-col gap-32" novalidate>
            <slot />
          </form>
        </div>
      </div>
      <div
        class="max-w-0 shrink-0 overflow-hidden transition-all duration-300 ease-in-out lg:sticky lg:top-0 lg:h-[calc(100dvh-var(--header-height))]"
        x-cloak
        :class="hintId ? 'max-w-full opacity-100 lg:max-w-[360px]' : 'max-w-0 opacity-0'"
      >
        <div class="h-full w-full lg:w-[360px]">
          <HintSidebar class="h-full overflow-y-auto">
            <slot name="hint" />
          </HintSidebar>
        </div>
      </div>
    </div>
    {
      Astro.slots.has("button-bar") ? (
        <slot name="button-bar" />
      ) : (
        <ButtonBar prevPath={prevPath} nextPath={nextPath} />
      )
    }
  </main>
</Layout>

<style is:global>
  @reference "@/styles/global.css";

  .kern-form-input .kern-error {
    display: none;
  }

  .kern-form-input__input:invalid {
    @apply kern-form-input__input--error;
  }

  .kern-form-input__input:invalid:focus {
    @apply kern-form-input__input--error-focus;
  }

  .kern-form-input__input:invalid ~ .kern-error {
    display: flex;
  }

  .kern-form-input:has(.kern-form-input__input:invalid) {
    @apply kern-form-input--error;
  }
</style>

<script>
  import { generateSteckbriefDocx } from "../_utils/docxDownload.ts";
  import type { Inputs } from "../_utils/types.ts";

  const STORAGE_KEY = "steckbrief-prototype-v2-form-state";

  const getState = () =>
    JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}") as Inputs;

  function init() {
    const form = document.querySelector("form");

    const handleFormChange = function () {
      if (!form) return;
      const formData = Object.fromEntries(new FormData(form).entries());
      const newState = { ...getState(), ...formData };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(newState));
    };
    form?.addEventListener("change", handleFormChange);

    // Fill form with localStorage data
    for (const [key, value] of Object.entries(getState())) {
      if (!value) continue;
      const el = form?.querySelector(`#${key}`) as HTMLInputElement;
      if (el) {
        el.value = value;
        el.dispatchEvent(new Event("input", { bubbles: true })); // trigger char-count in Textarea
      }

      const summaryEl = form?.querySelector(`#summary-${key}`);
      if (summaryEl) summaryEl.innerHTML = value;
    }

    const downloadDocx = () => {
      const data = getState();
      generateSteckbriefDocx(data);
    };

    const downloadBtns = document.querySelectorAll(".docx-download-btn");
    downloadBtns.forEach((btn) => btn.addEventListener("click", downloadDocx));
  }

  // astro:page-load fires on initial load and after every ClientRouter navigation
  document.addEventListener("astro:page-load", init);
</script>
