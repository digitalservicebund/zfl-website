---
import Layout from "@/layouts/Layout.astro";
import { vorhaben_phase2_ergebnisArbeitshilfenCheck } from "@/config/routes";

export const frontmatter = {
  title: "Start der Wirkkonzept-Erarbeitung",
  sitemap: false,
  navOrder: 1,
};
---

<Layout title={frontmatter.title}>
  <main class="breakout-grid">
    <section class="mx-auto max-w-730">
      <h1>{frontmatter.title}</h1>
      <p class="kern-body">
        Damit bei der Erarbeitung des Wirkkonzepts sämtliche Formalitäten von
        Grund auf mitgedacht werden, unterstützen wir Sie bei der
        Berücksichtigung von Checks und Arbeitshilfen.
      </p>

      <div class="mt-md">
        <label class="kern-label" for="phase2-freitext"
          >Kopieren Sie dafür Ihren finalen Steckbrief in dieses Textfeld.</label
        >
        <textarea
          id="phase2-freitext"
          name="phase2-freitext"
          class="kern-form-input__input min-h-180 w-full"
          placeholder="Hier Text einfügen..."></textarea>
      </div>
      <div class="mt-md">
        <button
          id="feedback-erstellen-btn"
          type="button"
          class="kern-btn kern-btn--primary"
          data-target-path={vorhaben_phase2_ergebnisArbeitshilfenCheck.path}
        >
          <span class="kern-label">Feedback erstellen</span>
          <span class="phase2-loader-backdrop" aria-hidden="true">
            <span class="phase2-loader"></span>
          </span>
        </button>
      </div>
      <div id="feedback-response" class="mt-md hidden">
        <div class="kern-body p-md rounded border border-gray-300 bg-gray-50">
          <p class="font-semibold">Feedback:</p>
          <p id="feedback-response-text"></p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  #feedback-erstellen-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  #feedback-erstellen-btn .phase2-loader-backdrop {
    display: none;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 9999px;
    background: rgb(255 255 255 / 0.28);
  }

  #feedback-erstellen-btn[data-loading="true"] {
    opacity: 0.95;
    pointer-events: none;
  }

  #feedback-erstellen-btn[data-loading="true"] .phase2-loader-backdrop {
    display: inline-flex;
  }

  .phase2-loader {
    width: 14px;
    height: 14px;
    border: 2px solid rgb(255 255 255 / 0.45);
    border-top-color: #fff;
    border-radius: 9999px;
    animation: phase2-spin 0.8s linear infinite;
  }

  @keyframes phase2-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  import { runAIPrompt } from "@/utils/promptAPIClient";

  function initFeedbackButtonLoader() {
    const button = document.querySelector("#feedback-erstellen-btn");
    const textarea = document.querySelector("#phase2-freitext");
    if (!(button instanceof HTMLButtonElement)) return;
    if (!(textarea instanceof HTMLTextAreaElement)) return;

    button.addEventListener("click", async () => {
      if (button.dataset.loading === "true") return;

      button.dataset.loading = "true";
      button.disabled = true;
      const prompt = textarea.value.trim();

      try {
        const feedbackDiv = document.querySelector("#feedback-response");
        const feedbackText = document.querySelector("#feedback-response-text");

        if (!prompt) {
          if (feedbackDiv && feedbackText) {
            feedbackText.textContent =
              "Bitte fugen Sie zuerst den Text aus dem Steckbrief ein.";
            feedbackDiv.classList.remove("hidden");
          }
          return;
        }

        const response = await runAIPrompt(prompt);

        if (feedbackDiv && feedbackText) {
          feedbackText.textContent = response || "Keine Antwort erhalten.";
          feedbackDiv.classList.remove("hidden");
        }
      } catch (error) {
        console.error("Fehler beim Abrufen des Feedbacks:", error);
      } finally {
        button.dataset.loading = "false";
        button.disabled = false;
        // const targetPath = button.dataset.targetPath;
        // if (targetPath) {
        //   window.location.href = targetPath;
        // }
      }
    });
  }

  document.addEventListener("astro:page-load", initFeedbackButtonLoader);
</script>
