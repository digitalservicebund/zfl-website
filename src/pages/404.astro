---
import { routes } from "@/config/routes";
import BreakoutLayout from "@/layouts/BreakoutLayout.astro";
---

<BreakoutLayout title="Seite nicht gefunden">
  <section id="error" class="space-y-md bg-lavender-base px-16 py-16 md:py-32">
    <span class="ds-label-01-bold">404</span><h1
      class="ds-heading-02-reg sm:hyphens-none"
    >
      Seite konnte nicht gefunden werden
    </h1><div class="ds-subhead space-y-8">
      <p>
        Es tut uns leid. Diese Seite gibt es nicht mehr oder ihr Name wurde
        geändert.
      </p>
      <ul>
        <li>
          Wenn Sie die URL direkt eingegeben haben, überprüfen Sie die
          Schreibweise.
        </li>
        <li>
          Versuchen Sie, die Seite von der Startseite aus erneut zu finden.
        </li>
      </ul>
    </div>
    <a
      id="error-back-button"
      data-testid="error-back-button"
      class="link-unstyled ds-button"
      href={routes.home.path}
      data-discover="true"
    >
      <span class="ds-button-label">Zurück zur Startseite</span>
    </a>
  </section>
</BreakoutLayout>
