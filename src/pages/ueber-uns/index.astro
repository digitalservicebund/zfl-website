---
import Hero from "@/components/Hero.astro";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Card from "@/components/Card.astro";
import zusammenarbeitImg from "@/images/Zusammenarbeit.png";
import ansatzImg from "@/images/Ansatz.jpg";
import { routes } from "@/config/routes.ts";

export const frontmatter = {
  title: "Über das Zentrum für Legistik",
  sitemap: true,
};
---

<Layout title={frontmatter.title}>
  <main class="breakout-grid">
    <Hero>
      <h1 class="kern-heading-display">
        Zentrale Anlaufstelle für Rechtsetzung
      </h1>
      <p class="kern-subline kern-subline--large">
        Das Zentrum für Legistik unterstützt bei der Gestaltung von Regelungen,
        die adressatenorientiert, praxistauglich und digital umsetzbar sind.<br
        />
        Derzeit wird das Zentrum vom Bundesministerium für Digitales und Staatsmodernisierung
        gemeinsam mit dem DigitalService aufgebaut. Alle Angebote werden dabei im
        engen Austausch mit der Praxis weiterentwickelt.
      </p>
    </Hero>

    <section>
      <div class="flex flex-col md:flex-row gap-32">
        <div class="md:w-1/3">
          <Image src={zusammenarbeitImg} alt="Mehrere Personen" />
        </div>
        <div class="md:w-2/3">
          <h2>Wirkung der Zusammenarbeit</h2>
          <p>
            Wir unterstützen Sie dabei, Umsetzungsprozesse zu verstehen und
            Anforderungen an praxisnahe und bürokratiearme Regelungen
            umzusetzen. Durch Ihre Rechtsetzungs-Expertise in Kombination mit
            Methoden aus der agilen Software-Entwicklung entstehen somit
            praxistaugliche und zukunftsfähige Gesetze, die unter anderem die
            Potenziale der Digitalisierung bestmöglich ausschöpfen.
          </p>
        </div>
      </div>
    </section>

    <section class="breakout bg-lavender-400">
      <div class="flex flex-col-reverse md:flex-row-reverse gap-32">
        <div class="md:w-1/3">
          <Image src={ansatzImg} alt="Mehrere Personen" />
        </div>
        <div class="md:w-2/3">
          <h2>Wo wir ansetzen</h2>
          <p>
            Rechtsetzung kann noch wirksamer werden, wenn sie von Anfang an die
            technischen Realitäten und die Bedarfe der Betroffenen
            berücksichtigt. Über die Jahre ist eine Vielzahl von Checklisten und
            Arbeitshilfen entstanden. Diese bestehenden Angebote lassen sich
            bündeln und durch neue Arbeitsweisen sinnvoll ergänzen. So entsteht
            ein verlässliches Serviceangebot, das den gesamten
            Gesetzgebungsprozess unterstützt.
          </p>
        </div>
      </div>
    </section>

    <section>
      <h2>Unsere Angebote</h2>
      <p>
        Das Serviceangebot wird laufend mit den Nutzerinnen und Nutzern
        weiterentwickelt und umfasst derzeit drei Schwerpunkte:
      </p>

      <div class="mt-40 flex flex-col gap-32 md:w-full md:flex-row md:gap-64">
        <div
          class="md:size-lg flex h-auto w-full flex-col gap-8 md:flex-1 md:gap-32"
        >
          <Icon class="feature-icon" name="ic:twotone-computer" />
          <div class="space-y-8">
            <h3 class="ds-heading-03-bold sm:hyphens-none md:pr-32">Website</h3>
            <p>
              Bereitstellung von <a href={routes.anleitungenUndHilfsmittel.path}
                >Anleitungen, Vorlagen, Werkzeugen und Methoden</a
              >
              für wirksame Rechtssetzung.
            </p>
          </div>
        </div>
        <div
          class="flex h-auto w-full flex-col gap-8 md:h-[298px] md:flex-1 md:gap-32"
        >
          <Icon class="feature-icon" name="ic:twotone-groups" />
          <div class="space-y-8">
            <h3 class="ds-heading-03-bold sm:hyphens-none md:pr-32">
              Interdisziplinäre Begleitung
            </h3>
            <p>
              <a href={routes.begleitungen.path}>Unterstützung von Vorhaben</a> durch
              Teams aus Design, Nutzerforschung, Softwareentwicklung und Produktmanagement.
            </p>
          </div>
        </div>
        <div
          class="flex h-auto w-full flex-col gap-8 md:h-[298px] md:flex-1 md:gap-32"
        >
          <Icon class="feature-icon" name="ic:twotone-school" />
          <div class="space-y-8">
            <h3 class="ds-heading-03-bold sm:hyphens-none md:pr-32">
              Schulungen
            </h3>
            <p>
              <a href={routes.schulungen.path}>
                Vermittlung von Methodenwissen
              </a>
              in virtuellen Formaten und Workshops.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section>
      <Card
        look="cosmic"
        class="flex justify-center py-48 md:py-56 max-md:rounded-none"
      >
        <h3>Wie wir arbeiten</h3>
        <p>
          Themen an denen wir aktuell arbeiten finden Sie auf dieser Seite: <a
            href={routes.ueberUns.children.daranArbeitenWir.path}
            >Daran arbeiten wir</a
          >.
        </p>
      </Card>
    </section>

    <section class="breakout bg-lavender-400">
      <h3>Politischer Auftrag</h3>
      <p>
        Der Auftrag ist in der <a
          href="https://bmds.bund.de/fileadmin/BMDS/Dokumente/Modernisierungsagenda_barrierefrei.pdf"
          >Modernisierungsagenda des Bundes</a
        > (Abschnitt II "Bessere Rechtsetzung") und der föderalen Modernisierungsagenda
        (Fünftes Kapitel) verankert. Als zentrale Plattform unterstützen wir dabei,
        praxisnahes, adressatenorientiertes, digital gut umsetzbares und bürokratiearmes
        Recht zu erarbeiten. Wir bauen auf den Erfahrungen des Digitalcheck auf, den
        der DigitalService seit 2023 anbietet.
      </p>
    </section>
  </main>
</Layout>

<style>
  @reference "@/styles/global.css";

  .feature-icon {
    @apply text-cosmic-blue-400 bg-lavender-400 size-[110px] flex-none rounded-sm px-[18px] py-[22px];
  }
</style>
