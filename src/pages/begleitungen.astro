---
import SupportCard from "@/components/blocks/SupportCard.astro";
import Card from "@/components/Card.astro";
import Hero from "@/components/Hero.astro";
import begleitungenImage from "@/images/Begleitungen.png";
import trainingsImage from "@/images/Trainings.jpg";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getImage, Image } from "astro:assets";
import { routes } from "@/config/routes.ts";

const trainingsImageAsset = await getImage({ src: trainingsImage });
const trainingsImageAssetURL = `url("${trainingsImageAsset.src}")`;

export const frontmatter = {
  title: routes.begleitungen.title,
  sitemap: true,
};
---

<Layout title={frontmatter.title}>
  <main class="breakout-grid max-md:overflow-x-hidden">
    <Hero>
      <h1>Regelungsbegleitung</h1>
      <div class="mt-md space-y-md relative gap-32 md:flex md:flex-row">
        <div class="kern-subline kern-subline--large">
          <h2>
            Individuelle Unterstützung für Ihr Vorhaben nutzen
          </h2>
          <p>
            Ein in Gesetzgebungspraxis erfahrenes interdisziplinäres Team
            unterstützt Sie dabei, die Regelung praxisnah, digitaltauglich und
            bürokratiearm zu gestalten.
          </p>
          <p>
            Vertraulich und mit individuellem Fokus auf Ihr Vorhaben stehen
            Ihnen während der Begleitung Kompetenzen in Design, Nutzerforschung,
            IT, Produkt- und Prozessmanagement direkt zur Verfügung.
          </p>
          <a class="kern-btn kern-btn--primary" href="#leistungspakete">
            <span class="kern-icon kern-icon--arrow-down" aria-hidden="true"
            ></span>
            <span class="kern-label">Leistungspakete anzeigen</span>
          </a>
        </div>
        <Image
          class="hidden size-288 md:block"
          src={begleitungenImage}
          alt=""
        />
      </div>
    </Hero>
    <section>
      <h2>Wirkung der Zusammenarbeit</h2>
      <p>
        Wir unterstützen Sie dabei, Umsetzungsprozesse zu verstehen und
        Anforderungen an praxisnahe und bürokratiearme Regelungen umzusetzen.
        Durch Ihre Rechtsetzungs-Expertise in Kombination mit Methoden aus der
        agilen Software-Entwicklung entstehen somit praxistaugliche und
        zukunftsfähige Gesetze, die unter anderem die Potenziale der
        Digitalisierung bestmöglich ausschöpfen.
      </p>

      <div
        class="mt-40 flex w-2xs flex-col gap-32 md:w-full md:flex-row md:gap-16"
      >
        <div
          class="md:size-lg flex h-auto w-full flex-col gap-8 md:flex-1 md:gap-32"
        >
          <Icon class="feature-icon" name="ic:twotone-account-tree" />
          <div class="space-y-8">
            <h3 class="ds-heading-03-bold sm:hyphens-none md:pr-32">
              Sachverhalte visualisieren
            </h3>
            <p>
              Komplexe Sachverhalte durch Prozess-Visualisierungen
              strukturieren, interne und externe Abstimmung vereinfachen
            </p>
          </div>
        </div>
        <div
          class="flex h-auto w-full flex-col gap-8 md:h-[298px] md:flex-1 md:gap-32"
        >
          <Icon class="feature-icon" name="ic:twotone-lightbulb" />
          <div class="space-y-8">
            <h3 class="ds-heading-03-bold sm:hyphens-none md:pr-32">
              Umsetzung mitdenken
            </h3>
            <p>
              Betroffenen-Perspektive frühzeitig identifizieren, bestehende
              Umsetzungshürden beheben
            </p>
          </div>
        </div>
        <div
          class="flex h-auto w-full flex-col gap-8 md:h-[298px] md:flex-1 md:gap-32"
        >
          <Icon class="feature-icon" name="ic:twotone-hub" />
          <div class="space-y-8">
            <h3 class="ds-heading-03-bold sm:hyphens-none md:pr-32">
              Prozesse strukturieren
            </h3>
            <p>
              Methodische Unterstützung nutzen, Anleitungen für Praxis- und
              Digitaltauglichkeit erhalten
            </p>
          </div>
        </div>
      </div>
      <div id="leistungspakete">
        <h2 class="mt-lg">Passende Leistungspakete für Ihr Vorhaben</h2>
        <p class="pb-40">
          Hier sehen Sie unsere verschiedenen Unterstützungsangebote im
          Vergleich. Alle Angebote sind für Sie kostenfrei und werden vom BMDS
          finanziert.
        </p>
        <div class="overflow-x-auto" tabindex="0">
          <table class="w-full table-fixed text-left">
            <thead>
              <tr class="table-header-cell">
                <th scope="col" class="w-[150px]"> Kriterien </th>
                <th scope="col" class="w-[235px]"> Paket S </th>
                <th scope="col" class="w-[235px]"> Paket M </th>
                <th scope="col" class="w-[235px]"> Paket L </th>
              </tr>
            </thead>

            <tbody
              class="table-body-cell [&>tr:nth-child(even)]:bg-lavender-200 [&>tr:nth-child(odd)]:bg-white"
            >
              <tr>
                <td class="font-bold"> Fokus </td>
                <td> Punktuelle Unterstützung bei Ihrer Fragestellung </td>
                <td> Vertiefte Analyse Ihres Vorhabens </td>
                <td> Langfristige Begleitung des Gesetzgebungsprozesses </td>
              </tr>

              <tr>
                <td class="font-bold"> Dauer </td>
                <td>1 gemeinsame Arbeitssitzung</td>
                <td>ca. 4 Wochen</td>
                <td>Ab 5 Wochen</td>
              </tr>

              <tr>
                <td class="font-bold"> Team </td>
                <td>
                  <div class="mb-1">1–2 Personen aus:</div>
                  <ul class="list-items">
                    <li>Service Design</li>
                    <li>Nutzerforschung</li>
                  </ul>
                </td>
                <td>
                  <div class="mb-1">3–4 Personen aus:</div>
                  <ul class="list-items">
                    <li>Service Design</li>
                    <li>Nutzerforschung</li>
                    <li>Softwareentwicklung</li>
                    <li>Produktmanagement</li>
                    <li>Transformations&shy;management</li>
                  </ul>
                </td>
                <td>
                  <div class="mb-1">3–4 Personen aus:</div>
                  <ul class="list-items">
                    <li>Service Design</li>
                    <li>Nutzerforschung</li>
                    <li>Softwareentwicklung</li>
                    <li>Produktmanagement</li>
                    <li>Transformations&shy;management</li>
                  </ul>
                </td>
              </tr>

              <tr>
                <td class="font-bold"> Zeitpunkt </td>
                <td> Individuell nach Bedarf </td>
                <td> Konzept- bis Entwurfsphase </td>
                <td> Ab Start der Initiative </td>
              </tr>

              <tr>
                <td class="font-bold"> Tätigkeit (Beispiele) </td>
                <td>
                  <ul class="list-items">
                    <li>Umsetzungsperspektive besser verstehen</li>
                    <li>gemeinsam visualisieren</li>
                    <li>technische Fragen beantworten</li>
                  </ul>
                </td>
                <td>
                  <ul class="list-items">
                    <li>
                      Umsetzungsperspektive auf technischer, organisatorischer
                      und rechtlicher Ebene durchdenken
                    </li>
                    <li>technische Lösungsideen entwickeln</li>
                    <li>Machbarkeit validieren</li>
                  </ul>
                </td>
                <td>
                  <ul class="list-items">
                    <li>Gemeinsame Analyse</li>
                    <li>Unterstützung bei Workshops und Hausabstimmungen</li>
                    <li>moderierter Austausch mit Umsetzungsakteuren</li>
                    <li>Evaluation von Lösungen</li>
                  </ul>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
    <section class="bg-lavender-base breakout py-80">
      <SupportCard />
    </section>
    <section
      class="breakout bg-cover bg-center"
      style={{ backgroundImage: trainingsImageAssetURL }}
    >
      <Card>
        <h3>
          Praxisbeispiel: Einsatz eines interdisziplinären Kompetenzteams für
          das Stromsteuerrecht
        </h3>
        <p>
          „Die gründliche Analyse von Vollzugsprozessen hat uns geholfen, das
          Zusammenspiel zwischen den Regelungen und der Administration besser zu
          verstehen und so den digitalen Vollzug zu gestalten.“
        </p>
        <a
          href="https://digitalcheck.bund.de/beispiele/regelungen/gesetz-zur-modernisierung-und-zum-buerokratieabbau-im-strom-und-energiesteuerrecht"
        >
          Mehr erfahren
        </a>
      </Card>
    </section>
  </main>
</Layout>

<style>
  @reference "@/styles/global.css";

  .feature-icon {
    @apply text-cosmic-blue-400 bg-lavender-400 size-[110px] flex-none rounded-sm px-[18px] py-[22px];
  }

  .list-items {
    @apply space-y-1;
  }
</style>
