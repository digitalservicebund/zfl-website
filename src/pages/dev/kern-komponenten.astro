---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero.astro";

export const frontmatter = {
  title: "KERN Komponenten",
  sitemap: false,
  isStagingOnly: true,
};
---

<Layout title={frontmatter.title}>
  <main class="breakout-grid">
    <Hero>
      <h1>KERN UX Komponenten</h1>
    </Hero>
    <!-- =========================================================
           TYPOGRAFIE
      ========================================================== -->
    <section aria-labelledby="typo-heading">
      <h2 class="kern-heading-large" id="typo-heading">Typografie</h2>

      <h3 class="kern-heading-medium">Headings</h3>
      <h1 class="kern-heading-display">heading-display</h1>
      <h2 class="kern-heading-x-large">heading-x-large</h2>
      <h2 class="kern-heading-large">heading-large</h2>
      <h3 class="kern-heading-medium">heading-medium</h3>
      <h4 class="kern-heading-small">heading-small</h4>

      <hr class="kern-divider" aria-hidden="true" />

      <h3 class="kern-heading-medium">Title</h3>
      <p class="kern-title kern-title--large">title--large</p>
      <p class="kern-title">title (default)</p>
      <p class="kern-title kern-title--small">title--small</p>

      <hr class="kern-divider" aria-hidden="true" />

      <h3 class="kern-heading-medium">Body</h3>
      <p class="kern-body kern-body--large">
        body--large: Fließtext in großer Größe
      </p>
      <p class="kern-body">body (default): Standardfließtext für Inhalte</p>
      <p class="kern-body kern-body--small">body--small: Kleinerer Fließtext</p>
      <p class="kern-body kern-body--bold">body--bold: Fetter Fließtext</p>
      <p class="kern-body kern-body--muted">
        body--muted: Gedämpfter Fließtext
      </p>

      <hr class="kern-divider" aria-hidden="true" />

      <h3 class="kern-heading-medium">Subline & Preline</h3>
      <p class="kern-preline kern-preline--large">preline--large</p>
      <p class="kern-preline">preline (default)</p>
      <p class="kern-preline kern-preline--small">preline--small</p>
      <p class="kern-subline kern-subline--large">subline--large</p>
      <p class="kern-subline">subline (default)</p>
      <p class="kern-subline kern-subline--small">subline--small</p>

      <hr class="kern-divider" aria-hidden="true" />

      <h3 class="kern-heading-medium">Label</h3>
      <p class="kern-label kern-label--large">label--large</p>
      <p class="kern-label">label (default)</p>
      <p class="kern-label kern-label--small">label--small</p>
      <label class="kern-label"
        >Mit optionalem Hinweis <span class="kern-label__optional"
          >- Optional</span
        ></label
      >

      <hr class="kern-divider" aria-hidden="true" />

      <h3 class="kern-heading-medium">Link</h3>
      <p class="kern-body">
        <a href="#" class="kern-link">Standardlink</a> ·
        <a href="#" class="kern-link">Besucht</a> ·
        <a href="#" class="kern-link"
          >Mit Icon <span
            class="kern-icon kern-icon--open-in-new"
            aria-hidden="true"></span></a
        >
      </p>
    </section>

    <hr class="kern-divider" aria-hidden="true" />

    <!-- =========================================================
           ICONS
      ========================================================== -->
    <section aria-labelledby="icons-heading">
      <h2 class="kern-heading-large" id="icons-heading">Icons</h2>

      <h3 class="kern-heading-medium">Größen</h3>
      <div class="flex flex-wrap items-center gap-16">
        <span
          class="kern-icon kern-icon--home kern-icon--small"
          aria-hidden="true"
          title="small"></span>
        <span
          class="kern-icon kern-icon--home"
          aria-hidden="true"
          title="default"></span>
        <span
          class="kern-icon kern-icon--home kern-icon--large"
          aria-hidden="true"
          title="large"></span>
        <span
          class="kern-icon kern-icon--home kern-icon--x-large"
          aria-hidden="true"
          title="x-large"></span>
      </div>
      <p class="kern-body kern-body--small kern-body--muted">
        small · default · large · x-large
      </p>

      <h3 class="kern-heading-medium">Glyphen-Auswahl</h3>
      <div class="flex flex-wrap items-center gap-12">
        {
          [
            "home",
            "arrow-up",
            "arrow-down",
            "arrow-forward",
            "arrow-back",
            "info",
            "success",
            "warning",
            "danger",
            "open-in-new",
            "download",
            "logout",
            "checklist",
            "mail",
            "edit",
            "sign-language",
            "easy-language",
            "autorenew",
            "add",
            "close",
            "delete",
            "search",
            "question-mark",
            "more-vert",
            "content-copy",
            "visibility",
            "visibility-off",
            "check",
            "drive-folder-upload",
            "chevron-left",
            "chevron-right",
            "keyboard-double-arrow-left",
            "keyboard-double-arrow-right",
            "brightness-medium",
            "light-mode",
            "dark-mode",
            "help",
            "calendar-today",
          ].map((name) => (
            <span
              class={`kern-icon kern-icon--${name}`}
              aria-hidden="true"
              title={name}
            />
          ))
        }
      </div>
    </section>

    <hr class="kern-divider" aria-hidden="true" />

    <!-- =========================================================
           BUTTON
      ========================================================== -->
    <section aria-labelledby="btn-heading">
      <h2 class="kern-heading-large" id="btn-heading">Button</h2>

      <h3 class="kern-heading-medium">Varianten</h3>
      <div class="flex flex-wrap items-center gap-16">
        <button class="kern-btn kern-btn--primary">
          <span class="kern-label">Primär</span>
        </button>
        <button class="kern-btn kern-btn--secondary">
          <span class="kern-label">Sekundär</span>
        </button>
        <button class="kern-btn kern-btn--tertiary">
          <span class="kern-label">Tertiär</span>
        </button>
      </div>

      <h3 class="kern-heading-medium">Mit Icons</h3>
      <div class="flex flex-wrap items-center gap-12">
        <button class="kern-btn kern-btn--primary">
          <span class="kern-icon kern-icon--edit" aria-hidden="true"></span>
          <span class="kern-label">Icon links</span>
        </button>
        <button class="kern-btn kern-btn--primary">
          <span class="kern-label">Icon rechts</span>
          <span class="kern-icon kern-icon--arrow-forward" aria-hidden="true"
          ></span>
        </button>
        <button class="kern-btn kern-btn--secondary">
          <span class="kern-icon kern-icon--edit" aria-hidden="true"></span>
          <span class="kern-label kern-sr-only">Bearbeiten (icon-only)</span>
        </button>
        <button class="kern-btn kern-btn--secondary">
          <span class="kern-icon kern-icon--edit" aria-hidden="true"></span>
          <span class="kern-label kern-sr-only-mobile"
            >Bearbeiten (mobil versteckt)</span
          >
        </button>
      </div>

      <h3 class="kern-heading-medium">Zustände</h3>
      <div class="flex flex-wrap items-center gap-12">
        <button class="kern-btn kern-btn--primary" disabled>
          <span class="kern-label">Primär disabled</span>
        </button>
        <button class="kern-btn kern-btn--secondary" disabled>
          <span class="kern-label">Sekundär disabled</span>
        </button>
        <button class="kern-btn kern-btn--tertiary" disabled>
          <span class="kern-label">Tertiär disabled</span>
        </button>
      </div>

      <h3 class="kern-heading-medium">Block</h3>
      <button class="kern-btn kern-btn--block kern-btn--primary">
        <span class="kern-label">Block-Button (volle Breite)</span>
      </button>
    </section>

    <hr class="kern-divider" aria-hidden="true" />

    <!-- =========================================================
           BADGE
      ========================================================== -->
    <section aria-labelledby="badge-heading">
      <h2 class="kern-heading-large" id="badge-heading">Badge</h2>
      <div class="flex flex-wrap items-center gap-12">
        <span class="kern-badge kern-badge--info">
          <span class="kern-label kern-label--small">Info</span>
        </span>
        <span class="kern-badge kern-badge--success">
          <span class="kern-icon kern-icon--success" aria-hidden="true"></span>
          <span class="kern-label kern-label--small">Erledigt</span>
        </span>
        <span class="kern-badge kern-badge--warning">
          <span class="kern-icon kern-icon--warning" aria-hidden="true"></span>
          <span class="kern-label kern-label--small">Warnung</span>
        </span>
        <span class="kern-badge kern-badge--danger">
          <span class="kern-icon kern-icon--danger" aria-hidden="true"></span>
          <span class="kern-label kern-label--small">Fehler</span>
        </span>
      </div>
    </section>

    <hr class="kern-divider" aria-hidden="true" />

    <!-- =========================================================
           ALERT
      ========================================================== -->
    <section aria-labelledby="alert-heading">
      <h2 class="kern-heading-large" id="alert-heading">Alert</h2>
      <div class="flex flex-col gap-12">
        <div class="kern-alert kern-alert--info" role="alert">
          <div class="kern-alert__header">
            <span class="kern-icon kern-icon--info" aria-hidden="true"></span>
            <span class="kern-title">Info-Hinweis</span>
          </div>
          <div class="kern-alert__body">
            <p class="kern-body">Dies ist eine informative Nachricht.</p>
          </div>
        </div>
        <div class="kern-alert kern-alert--success" role="alert">
          <div class="kern-alert__header">
            <span class="kern-icon kern-icon--success" aria-hidden="true"
            ></span>
            <span class="kern-title">Erfolgreich gespeichert</span>
          </div>
        </div>
        <div class="kern-alert kern-alert--warning" role="alert">
          <div class="kern-alert__header">
            <span class="kern-icon kern-icon--warning" aria-hidden="true"
            ></span>
            <span class="kern-title">Achtung: Bitte prüfen</span>
          </div>
          <div class="kern-alert__body">
            <p class="kern-body">
              Einige Angaben müssen noch vervollständigt werden.
            </p>
          </div>
        </div>
        <div class="kern-alert kern-alert--danger" role="alert">
          <div class="kern-alert__header">
            <span class="kern-icon kern-icon--danger" aria-hidden="true"></span>
            <span class="kern-title">Fehler aufgetreten</span>
          </div>
        </div>
      </div>
    </section>

    <hr class="kern-divider" aria-hidden="true" />

    <!-- =========================================================
           ACCORDION
      ========================================================== -->
    <section aria-labelledby="accordion-heading">
      <h2 class="kern-heading-large" id="accordion-heading">Accordion</h2>

      <h3 class="kern-heading-medium">Einzeln</h3>
      <details class="kern-accordion">
        <summary class="kern-accordion__header">
          <span class="kern-title">Geschlossener Accordion</span>
        </summary>
        <section class="kern-accordion__body">
          <p class="kern-body">
            Dieser Inhalt wird eingeblendet, wenn der Accordion geöffnet wird.
          </p>
        </section>
      </details>

      <details class="kern-accordion" open>
        <summary class="kern-accordion__header">
          <span class="kern-title">Geöffneter Accordion</span>
        </summary>
        <section class="kern-accordion__body">
          <p class="kern-body">Dieser Inhalt ist bereits sichtbar (open).</p>
        </section>
      </details>

      <h3 class="kern-heading-medium">Gruppe</h3>
      <div class="kern-accordion-group">
        <details class="kern-accordion">
          <summary class="kern-accordion__header">
            <span class="kern-title">Abschnitt 1</span>
          </summary>
          <section class="kern-accordion__body">
            <p class="kern-body">Inhalt des ersten Abschnitts.</p>
          </section>
        </details>
        <details class="kern-accordion">
          <summary class="kern-accordion__header">
            <span class="kern-title">Abschnitt 2</span>
          </summary>
          <section class="kern-accordion__body">
            <p class="kern-body">Inhalt des zweiten Abschnitts.</p>
          </section>
        </details>
        <details class="kern-accordion" open>
          <summary class="kern-accordion__header">
            <span class="kern-title">Abschnitt 3 (offen)</span>
          </summary>
          <section class="kern-accordion__body">
            <p class="kern-body">Inhalt des dritten Abschnitts.</p>
          </section>
        </details>
      </div>
    </section>

    <hr class="kern-divider" aria-hidden="true" />

    <!-- =========================================================
           CARD
      ========================================================== -->
    <section aria-labelledby="card-heading">
      <h2 class="kern-heading-large" id="card-heading">Card</h2>

      <div class="flex flex-wrap items-start gap-24">
        <!-- Standard -->
        <article class="kern-card max-w-xs shrink grow basis-280">
          <div class="kern-card__container">
            <header class="kern-card__header">
              <p class="kern-preline">Preline</p>
              <h3 class="kern-title">Standard Card</h3>
              <p class="kern-subline">Subline</p>
            </header>
            <section class="kern-card__body">
              <p class="kern-body">
                Textinhalt der Card. Wächst flexibel mit dem Inhalt.
              </p>
            </section>
            <footer class="kern-card__footer">
              <button class="kern-btn kern-btn--primary">
                <span class="kern-label">Aktion</span>
              </button>
              <button class="kern-btn kern-btn--secondary">
                <span class="kern-label">Mehr</span>
              </button>
            </footer>
          </div>
        </article>

        <!-- Small -->
        <article
          class="kern-card kern-card--small max-w-280 shrink grow basis-240"
        >
          <div class="kern-card__container">
            <header class="kern-card__header">
              <p class="kern-preline">Preline</p>
              <h3 class="kern-title">Card --small</h3>
            </header>
            <section class="kern-card__body">
              <p class="kern-body">Kompaktere Variante.</p>
            </section>
            <footer class="kern-card__footer">
              <button class="kern-btn kern-btn--primary">
                <span class="kern-label">Aktion</span>
              </button>
            </footer>
          </div>
        </article>

        <!-- Large -->
        <article
          class="kern-card kern-card--large max-w-360 shrink grow basis-300"
        >
          <div class="kern-card__container">
            <header class="kern-card__header">
              <p class="kern-preline">Preline</p>
              <h3 class="kern-title">Card --large</h3>
              <p class="kern-subline">Subline</p>
            </header>
            <section class="kern-card__body">
              <p class="kern-body">Großzügigere Variante mit mehr Abstand.</p>
            </section>
            <footer class="kern-card__footer">
              <button class="kern-btn kern-btn--primary">
                <span class="kern-label">Aktion</span>
              </button>
            </footer>
          </div>
        </article>

        <!-- Hug -->
        <article
          class="kern-card kern-card--hug max-w-280 shrink grow basis-240"
        >
          <div class="kern-card__container">
            <header class="kern-card__header">
              <h3 class="kern-title">Card --hug</h3>
            </header>
            <section class="kern-card__body">
              <p class="kern-body">Kein Equal-Height-Stretching.</p>
            </section>
          </div>
        </article>
      </div>
    </section>

    <hr class="kern-divider" aria-hidden="true" />

    <!-- =========================================================
           LISTS
      ========================================================== -->
    <section aria-labelledby="lists-heading">
      <h2 class="kern-heading-large" id="lists-heading">Listen</h2>

      <div class="flex flex-wrap items-start gap-32">
        <div>
          <h3 class="kern-heading-medium">Bullet</h3>
          <ul class="kern-list kern-list--bullet">
            <li><span class="kern-body">Listenpunkt eins</span></li>
            <li><span class="kern-body">Listenpunkt zwei</span></li>
            <li><span class="kern-body">Listenpunkt drei</span></li>
          </ul>
        </div>
        <div>
          <h3 class="kern-heading-medium">Nummeriert</h3>
          <ol class="kern-list kern-list--number">
            <li><span class="kern-body">Erster Schritt</span></li>
            <li><span class="kern-body">Zweiter Schritt</span></li>
            <li><span class="kern-body">Dritter Schritt</span></li>
          </ol>
        </div>
        <div>
          <h3 class="kern-heading-medium">Bullet --small</h3>
          <ul class="kern-list kern-list--bullet kern-list--small">
            <li>
              <span class="kern-body kern-body--small">Kleiner Punkt</span>
            </li>
            <li>
              <span class="kern-body kern-body--small">Noch ein Punkt</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="kern-heading-medium">Bullet --large</h3>
          <ul class="kern-list kern-list--bullet kern-list--large">
            <li>
              <span class="kern-body kern-body--large">Großer Punkt</span>
            </li>
            <li>
              <span class="kern-body kern-body--large">Noch ein Punkt</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <hr class="kern-divider" aria-hidden="true" />

    <!-- =========================================================
           FORM CONTROLS
      ========================================================== -->
    <section aria-labelledby="form-heading" class="space-y-md">
      <h2 class="kern-heading-large" id="form-heading">Formulare</h2>

      <div class="flex flex-wrap items-start gap-32">
        <!-- Text Input -->
        <div class="shrink grow basis-260">
          <h3 class="kern-heading-medium">Text</h3>
          <div class="kern-form-input">
            <label class="kern-label" for="demo-text"
              >Name <span class="kern-label__optional">- Optional</span></label
            >
            <div class="kern-hint" id="demo-text-hint">
              Ihr vollständiger Name
            </div>
            <input
              class="kern-form-input__input"
              id="demo-text"
              name="demo-text"
              type="text"
              aria-describedby="demo-text-hint"
            />
          </div>

          <h3 class="kern-heading-medium">Text – Fehler</h3>
          <div class="kern-form-input kern-form-input--error">
            <label class="kern-label" for="demo-text-err">Name</label>
            <input
              class="kern-form-input__input kern-form-input__input--error"
              id="demo-text-err"
              name="demo-text-err"
              type="text"
              aria-describedby="demo-text-error"
            />
            <p class="kern-error" id="demo-text-error" role="alert">
              <span class="kern-icon kern-icon--danger" aria-hidden="true"
              ></span>
              <span class="kern-body">Der Name darf nicht leer sein</span>
            </p>
          </div>
        </div>

        <!-- Email -->
        <div class="shrink grow basis-260">
          <h3 class="kern-heading-medium">Email</h3>
          <div class="kern-form-input">
            <label class="kern-label" for="demo-email">Email</label>
            <div class="kern-hint" id="demo-email-hint">
              Beispiel: name@domain.de
            </div>
            <input
              class="kern-form-input__input"
              id="demo-email"
              name="demo-email"
              type="email"
              autocomplete="email"
              aria-describedby="demo-email-hint"
            />
          </div>
        </div>

        <!-- Password -->
        <div class="shrink grow basis-260">
          <h3 class="kern-heading-medium">Passwort</h3>
          <div class="kern-form-input">
            <label class="kern-label" for="demo-pw">Passwort</label>
            <input
              class="kern-form-input__input"
              id="demo-pw"
              name="demo-pw"
              type="password"
              autocomplete="current-password"
            />
          </div>
        </div>

        <!-- Tel -->
        <div class="shrink grow basis-260">
          <h3 class="kern-heading-medium">Telefon</h3>
          <div class="kern-form-input">
            <label class="kern-label" for="demo-tel">Telefonnummer</label>
            <input
              class="kern-form-input__input"
              id="demo-tel"
              name="demo-tel"
              type="tel"
              autocomplete="tel"
            />
          </div>
        </div>

        <!-- Number -->
        <div class="shrink grow basis-260">
          <h3 class="kern-heading-medium">Zahl</h3>
          <div class="kern-form-input">
            <label class="kern-label" for="demo-num">Anzahl</label>
            <input
              class="kern-form-input__input"
              id="demo-num"
              name="demo-num"
              type="text"
              inputmode="numeric"
            />
          </div>
        </div>

        <!-- Textarea -->
        <div class="shrink grow basis-xs">
          <h3 class="kern-heading-medium">Textarea</h3>
          <div class="kern-form-input">
            <label class="kern-label" for="demo-area">Beschreibung</label>
            <div class="kern-hint" id="demo-area-hint">Maximal 500 Zeichen</div>
            <textarea
              class="kern-form-input__input"
              id="demo-area"
              name="demo-area"
              rows="4"
              aria-describedby="demo-area-hint"></textarea>
          </div>
        </div>

        <!-- File -->
        <div class="shrink grow basis-260">
          <h3 class="kern-heading-medium">Datei-Upload</h3>
          <div class="kern-form-input">
            <label class="kern-label" for="demo-file">Datei hochladen</label>
            <div class="kern-hint" id="demo-file-hint">
              Erlaubte Formate: jpg, png, pdf
            </div>
            <input
              class="kern-form-input__input"
              id="demo-file"
              name="demo-file"
              type="file"
              aria-describedby="demo-file-hint"
            />
          </div>
        </div>

        <!-- Select -->
        <div class="shrink grow basis-260">
          <h3 class="kern-heading-medium">Select</h3>
          <div class="kern-form-input">
            <label class="kern-label" for="demo-select">Auswählen</label>
            <div class="kern-hint" id="demo-select-hint">
              Bitte wählen Sie eine Option
            </div>
            <div class="kern-form-input__select-wrapper">
              <select
                class="kern-form-input__select"
                id="demo-select"
                name="demo-select"
                aria-describedby="demo-select-hint"
              >
                <option value="">Bitte wählen …</option>
                <option value="1">Option 1</option>
                <option value="2">Option 2</option>
                <option value="3">Option 3</option>
              </select>
            </div>
          </div>

          <h3 class="kern-heading-medium">Select – Fehler</h3>
          <div class="kern-form-input kern-form-input--error">
            <label class="kern-label" for="demo-select-err">Auswählen</label>
            <div class="kern-form-input__select-wrapper">
              <select
                class="kern-form-input__select kern-form-input__select--error"
                id="demo-select-err"
                name="demo-select-err"
                aria-describedby="demo-select-error"
              >
                <option value="">Bitte wählen …</option>
                <option value="1">Option 1</option>
              </select>
            </div>
            <p class="kern-error" id="demo-select-error" role="alert">
              <span class="kern-icon kern-icon--danger" aria-hidden="true"
              ></span>
              <span class="kern-body">Bitte wählen Sie eine gültige Option</span
              >
            </p>
          </div>
        </div>
      </div>

      <!-- Checkbox & Radio -->
      <h3 class="kern-heading-medium">Checkbox & Radio</h3>
      <div class="flex flex-wrap items-start gap-32">
        <div>
          <div class="kern-form-check">
            <input
              class="kern-form-check__checkbox"
              id="demo-cb1"
              type="checkbox"
            />
            <label class="kern-label" for="demo-cb1">Option A</label>
          </div>
          <div class="kern-form-check">
            <input
              class="kern-form-check__checkbox"
              id="demo-cb2"
              type="checkbox"
              checked
            />
