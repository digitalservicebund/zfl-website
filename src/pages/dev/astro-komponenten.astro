---
import Badge from "@/components/Badge.astro";
import Banner from "@/components/Banner.astro";
import InfoPanel from "@/components/InfoPanel.astro";
import FeatureItem from "@/components/FeatureItem.astro";
import FeatureSet from "@/components/FeatureSet.astro";
import Hero from "@/components/Hero.astro";
import HintSidebarWrapper from "@/components/HintSidebarWrapper.astro";
import KernBadge from "@/components/KernBadge.astro";
import KernCard from "@/components/KernCard.astro";
import MediaText from "@/components/MediaText.astro";
import Modal from "@/components/Modal.astro";
import PostTeaser from "@/components/PostTeaser.astro";
import TimelineList from "@/components/TimelineList.astro";
import trainingImage from "@/images/Trainings.jpg";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

export const frontmatter = {
  title: "Astro Komponenten",
  sitemap: false,
  isStagingOnly: true,
};
---

<Layout title={frontmatter.title}>
  <main class="breakout-grid">
    <Hero>
      <h1>Astro Komponenten</h1>
    </Hero>

    <!-- ─── Badge ─────────────────────────────────────────────────────── -->
    <section class="space-y-48">
      <h2>Badge</h2>

      <div class="space-y-32">
        <p class="variant-label kern-label">look: hint (default)</p>
        <Badge look="hint">Hinweistext</Badge>
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">look: gray</p>
        <Badge look="gray">Grauer Badge</Badge>
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">look: white</p>
        <div class="bg-lavender-400 p-16">
          <Badge look="white">Weißer Badge</Badge>
        </div>
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">mit Icon-Slot</p>
        <Badge look="hint">
          <Icon slot="icon" name="ic:outline-info" class="size-16" />
          Mit Icon
        </Badge>
      </div>
    </section>

    <!-- ─── KernBadge ─────────────────────────────────────────────────── -->
    <section class="space-y-48">
      <h2>KernBadge</h2>

      <div class="space-y-32">
        <p class="variant-label kern-label">vier Varianten</p>
        <div class="flex flex-wrap gap-12">
          <KernBadge variant="info">Information</KernBadge>
          <KernBadge variant="success">Erfolg</KernBadge>
          <KernBadge variant="warning">Warnung</KernBadge>
          <KernBadge variant="danger">Fehler</KernBadge>
        </div>
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">showIcon: false</p>
        <div class="flex flex-wrap gap-12">
          <KernBadge variant="info" showIcon={false}>Information</KernBadge>
          <KernBadge variant="success" showIcon={false}>Erfolg</KernBadge>
        </div>
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">small: true</p>
        <div class="flex flex-wrap gap-12">
          <KernBadge variant="warning" small={true}>Warnung</KernBadge>
          <KernBadge variant="danger" showIcon={false} small={true}
            >Fehler</KernBadge
          >
        </div>
      </div>
    </section>

    <!-- ─── Banner ────────────────────────────────────────────────────── -->
    <section class="breakout-grid contents">
      <h2 class="mt-32">Banner</h2>
      <Banner>
        <p class="mb-0">
          Dies ist ein Banner-Hinweis. Das Angebot befindet sich aktuell im
          Aufbau.
        </p>
        <a href="#">Mehr dazu</a>
      </Banner>
    </section>

    <!-- ─── InfoPanel ────────────────────────────────────────────────── -->
    <section class="space-y-48">
      <h2>InfoPanel</h2>

      <div class="space-y-32">
        <p class="variant-label kern-label">look: default (weiß)</p>
        <InfoPanel>
          <h3>Weiße Karte</h3>
          <p>Standardvariante ohne explizites look-Prop.</p>
        </InfoPanel>
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">look: lavender</p>
        <InfoPanel look="lavender">
          <h3>Lavendel-Karte</h3>
          <p>Hintergrund: <code>bg-lavender-400</code>.</p>
        </InfoPanel>
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">look: lightLavender</p>
        <InfoPanel look="lightLavender">
          <h3>Helles Lavendel</h3>
          <p>Hintergrund: <code>bg-lavender-200</code>.</p>
        </InfoPanel>
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">look: blue</p>
        <InfoPanel look="blue">
          <h3>Blaue Karte</h3>
          <p>Hintergrund: <code>bg-cosmic-blue-base</code>, weiße Schrift.</p>
        </InfoPanel>
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">padding: wide</p>
        <InfoPanel padding="wide">
          <h3>Breites Padding</h3>
          <p>Variante mit mehr horizontalem Innenabstand.</p>
        </InfoPanel>
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">mit Icon-Slot</p>
        <InfoPanel>
          <Icon name="ic:twotone-widgets" slot="icon" />
          <h3>Karte mit Icon</h3>
          <p>
            Beim Übergeben des Icon-Slots wird links ein farbiger Ikonbereich
            angezeigt.
          </p>
        </InfoPanel>
      </div>
    </section>

    <!-- ─── FeatureItem + FeatureSet ──────────────────────────────────── -->
    <section class="space-y-48">
      <h2>FeatureItem + FeatureSet</h2>

      <div class="space-y-32">
        <p class="variant-label kern-label">FeatureSet mit drei FeatureItems</p>
        <FeatureSet>
          <FeatureItem
            icon="ic:outline-check-circle"
            title="Betroffenenzentriert"
            body="Vorhaben konsequent aus der Perspektive Betroffener entwickeln."
          />
          <FeatureItem
            icon="ic:outline-build"
            title="Praxistauglich"
            body="Praktische Umsetzbarkeit von Anfang an mitdenken."
          />
          <FeatureItem
            icon="ic:outline-devices"
            title="Digital umsetzbar"
            body="Regelungen so gestalten, dass sie digital vollziehbar sind."
          >
            <a href="#">Mehr erfahren</a>
          </FeatureItem>
        </FeatureSet>
      </div>
    </section>

    <!-- ─── Hero ──────────────────────────────────────────────────────── -->
    <section class="breakout-grid contents">
      <h2 class="mt-32">Hero</h2>
      <p class="variant-label kern-label mt-32 mb-32">level: root</p>
      <Hero level="root">
        <h2 class="kern-heading-x-large py-0 text-white">
          Bessere Rechtsetzung
        </h2>
        <p slot="subtitle">
          Root-Level-Hero mit weißem Text auf dunkelblauem Hintergrund.
        </p>
      </Hero>
      <p class="variant-label kern-label mt-48 mb-32">level: main</p>
      <Hero level="main">
        <h2 class="kern-heading-x-large py-0">Hauptseite</h2>
        <p slot="subtitle">Main-Level-Hero, Lavendel-Hintergrund.</p>
      </Hero>
      <p class="variant-label kern-label mt-48 mb-32">level: sub (default)</p>
      <Hero>
        <h2 class="kern-heading-x-large py-0">Unterseite</h2>
      </Hero>
    </section>

    <!-- ─── HintSidebarWrapper ───────────────────────────────────────── -->
    <HintSidebarWrapper>
      <section class="space-y-48">
        <h2>HintSidebarWrapper</h2>
        <p>
          Hauptinhalt neben der ausklappbaren Sidebar. Die Sidebar wird über die
          Alpine.js-Variable <code>hintSidebarOpen</code> gesteuert.
        </p>
        <button
          class="border-cosmic-blue-base text-cosmic-blue-base rounded-sm border px-16 py-8"
          @click="hintSidebarOpen = !hintSidebarOpen"
          aria-label="Seitenleiste ein- oder ausblenden"
        >
          Sidebar öffnen/schließen
        </button>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
          eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad
          minim veniam, quis nostrud exercitation ullamco laboris nisi ut
          aliquip ex ea commodo consequat. Duis aute irure dolor in
          reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla
          pariatur. Excepteur sint occaecat cupidatat non proident, sunt in
          culpa qui officia deserunt mollit anim id est laborum.
        </p>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
          eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad
          minim veniam, quis nostrud exercitation ullamco laboris nisi ut
          aliquip ex ea commodo consequat. Duis aute irure dolor in
          reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla
          pariatur. Excepteur sint occaecat cupidatat non proident, sunt in
          culpa qui officia deserunt mollit anim id est laborum.
        </p>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
          eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad
          minim veniam, quis nostrud exercitation ullamco laboris nisi ut
          aliquip ex ea commodo consequat. Duis aute irure dolor in
          reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla
          pariatur. Excepteur sint occaecat cupidatat non proident, sunt in
          culpa qui officia deserunt mollit anim id est laborum.
        </p>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
          eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad
          minim veniam, quis nostrud exercitation ullamco laboris nisi ut
          aliquip ex ea commodo consequat. Duis aute irure dolor in
          reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla
          pariatur. Excepteur sint occaecat cupidatat non proident, sunt in
          culpa qui officia deserunt mollit anim id est laborum.
        </p>
      </section>

      <div slot="hintSidebarContent">
        <h3>Hinweis</h3>
        <p>
          Hier steht ein erklärender Hinweistext, der in der Sidebar angezeigt
          wird.
        </p>
      </div>
    </HintSidebarWrapper>

    <!-- ─── KernCard ──────────────────────────────────────────────────── -->
    <section class="space-y-48">
      <h2>KernCard</h2>

      <div class="space-y-32">
        <p class="variant-label kern-label">
          mit preline, subline und body (default: lavender-200)
        </p>
        <KernCard
          title="Mit Preline und Subline"
          preline="Kategorie"
          subline="Ergänzender Untertitel"
          body="Detailbeschreibung der Karte. Hier kann längerer Erklärungstext stehen."
        />
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">mit weißem Hintergrund</p>
        <KernCard
          title="Weiße Karte"
          preline="Variante"
          background="white"
          body="Diese Variante überschreibt den Standardhintergrund mit Weiß."
        />
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">interaktiv (mit href)</p>
        <KernCard
          title="Anklickbare Karte"
          preline="Interaktiv"
          href="https://example.com"
          body="Diese Karte ist vollständig klickbar durch den stretched-Link-Mechanismus."
        />
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">mit Bild</p>
        <KernCard
          title="Karte mit Bild"
          preline="Bild-Variante"
          image={trainingImage}
          imageAlt="Schulungssituation"
          imageSource="ZfL"
          body="Oben ein Bild, darunter Titel und Text."
        />
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">mit Footer-Slot</p>
        <KernCard
          title="Karte mit Footer"
          body="Der Footer-Bereich eignet sich für Links oder Metadaten."
        >
          <a href="#" slot="footer">Mehr erfahren →</a>
        </KernCard>
      </div>
    </section>

    <!-- ─── MediaText ─────────────────────────────────────────────────── -->
    <section class="space-y-48">
      <h2>MediaText</h2>

      <div class="space-y-32">
        <p class="variant-label kern-label">default (split: 7-5)</p>
        <MediaText>
          <div>
            <h3>Hauptinhalt (7/12)</h3>
            <p>
              Der größere linke Bereich enthält üblicherweise Fließtext oder
              Überschriften.
            </p>
          </div>
          <Image
            slot="media"
            src={trainingImage}
            alt="Schulungssituation"
            class="h-full w-full rounded-sm object-cover"
          />
        </MediaText>
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">reversed</p>
        <MediaText reversed>
          <div>
            <h3>Text rechts</h3>
            <p>
              Durch <code>reversed</code> wechseln Text und Medium die Seite.
            </p>
          </div>
          <Image
            slot="media"
            src={trainingImage}
            alt="Schulungssituation"
            class="h-full w-full rounded-sm object-cover"
          />
        </MediaText>
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">split: 8-4</p>
        <MediaText split="8-4">
          <div>
            <h3>Breiter Text (8/12)</h3>
            <p>
              Hier ist der Textbereich breiter und das Medium schmaler (4/12).
            </p>
          </div>
          <Image
            slot="media"
            src={trainingImage}
            alt="Schulungssituation"
            class="h-full w-full rounded-sm object-cover"
          />
        </MediaText>
      </div>
    </section>

    <!-- ─── Modal ────────────────────────────────────────────────────── -->
    <section class="space-y-48">
      <h2>Modal</h2>

      <div class="space-y-32">
        <button
          class="border-cosmic-blue-base text-cosmic-blue-base rounded-sm border px-16 py-8"
          popovertarget="demo-modal"
        >
          Modal öffnen
        </button>
        <Modal id="demo-modal">
          <h3>Beispiel-Modal</h3>
          <p>
            Dies ist ein modales Hinweisfenster. Es wird über die native
            Popover-API geöffnet und mit einem Fade-Effekt ein- und
            ausgeblendet.
          </p>
        </Modal>
      </div>
    </section>

    <!-- ─── PostTeaser ────────────────────────────────────────────────── -->
    <section class="space-y-48">
      <h2>PostTeaser</h2>

      <div class="space-y-32">
        <p class="variant-label kern-label">mit body</p>
        <PostTeaser
          date="15. April 2025"
          source="Bundesministerium der Justiz"
          title="Neue Leitlinien für bessere Rechtsetzung veröffentlicht"
          href="https://example.com"
          body="Das Ministerium hat heute überarbeitete Leitlinien veröffentlicht, die klare Vorgaben für verständliche und praxistaugliche Gesetze schaffen."
        />
      </div>

      <div class="space-y-32">
        <p class="variant-label kern-label">mit Bezahlinhalt</p>
        <PostTeaser
          date="16. April 2025"
          source="Fachmedium"
          title="Analyse zur besseren Rechtsetzung"
          href="https://example.com/paywalled"
          paywalled
          body="Dieser Beispielteaser zeigt die Kennzeichnung von Bezahlinhalten mit barrierefreiem Text für Screenreader."
        />
      </div>
    </section>

    <!-- ─── TimelineList ──────────────────────────────────────────────── -->
    <section class="space-y-48">
      <h2>TimelineList</h2>

      <div class="space-y-32">
        <TimelineList>
          <li>
            <h3>Phase 1: Analyse</h3>
            <p>Bestandsaufnahme der bestehenden Regelungen und Prozesse.</p>
          </li>
          <li>
            <h3>Phase 2: Entwurf</h3>
            <p>
              Erarbeitung eines Regelungsentwurfs unter Einbeziehung der
              Betroffenen.
            </p>
          </li>
          <li>
            <h3>Phase 3: Umsetzung</h3>
            <p>Inkraftsetzung und Begleitung der praktischen Umsetzung.</p>
          </li>
        </TimelineList>
      </div>
    </section>
  </main>
</Layout>

<style>
  .variant-label {
    &::before {
      content: "❯";
      color: var(--color-cosmic-blue-400);
      display: inline-block;
      margin-right: 0.5em;
    }
  }
</style>
