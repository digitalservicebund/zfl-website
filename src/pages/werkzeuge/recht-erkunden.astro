---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero.astro";
import NormDisplay from "@/components/NormDisplay.astro";
import { Icon } from "astro-icon/components";
import { tv } from "tailwind-variants";
import {
  HIERARCHY_LEVELS,
  RELEVANCE_REASONS,
  LAW_AREAS,
} from "./_recht-erkunden-data";

export const frontmatter = {
  title: "Recht erkunden",
  sitemap: false,
  isStagingOnly: true,
};

const description =
  "Prototyp: Ausgehend von einem Gesetz die passenden Rechtsgebiete, die zu ändernden Normen und das angrenzende Recht erkunden - strukturiert nach Normenhierarchie und Relevanzgrund.";

const styles = tv({
  slots: {
    searchInput:
      "focus:outline-cosmic-blue-base border-lavender-400 w-full rounded-sm border bg-white py-10 pr-40 pl-40 transition focus:outline-2",
    chip: "bg-lavender-base text-cosmic-blue-base inline-flex items-center gap-6 rounded-full px-10 py-4 text-left text-sm transition",
    termChip:
      "border-cosmic-blue-base text-cosmic-blue-base inline-flex items-center gap-8 rounded-full border bg-white px-12 py-6 text-left text-sm transition",
    lawCard:
      "group border-lavender-400 hover:border-cosmic-blue-400 flex w-full cursor-pointer flex-col items-start gap-4 rounded-sm border bg-white p-16 text-left transition",
    areaCard:
      "group flex w-full cursor-pointer flex-col items-start gap-8 rounded-sm border p-16 text-left transition",
    normRow: "flex items-start gap-12 rounded-sm border p-12 transition",
    countBadge:
      "bg-lavender-base text-cosmic-blue-base inline-flex w-fit items-center gap-6 rounded-full px-10 py-4 text-xs font-semibold",
    matrixHeaderCell:
      "border-lavender-400 bg-lavender-base border-b-2 p-12 text-left align-top",
    matrixRowLabel:
      "border-lavender-400 bg-lavender-100 border-b p-12 align-top whitespace-nowrap",
    matrixCell: "border-lavender-400 border-b p-12 align-top",
    sourceCard: "border-lavender-400 rounded-sm border bg-white p-12",
    selectedLawCard:
      "border-cosmic-blue-base bg-lavender-100 flex flex-wrap items-center justify-between gap-12 rounded-sm border p-16",
    infoTrigger:
      "text-cosmic-blue-base hover:bg-lavender-100 inline-flex h-22 w-22 items-center justify-center rounded-full transition",
    infoPopoverPanel:
      "border-lavender-400 text-icon-muted absolute top-full left-0 z-20 mt-4 w-260 rounded-sm border bg-white p-12 text-xs leading-snug font-normal shadow-lg",
    stepBadge:
      "bg-cosmic-blue-base flex h-32 w-32 shrink-0 items-center justify-center rounded-full text-base leading-none font-semibold text-white",
    subStepGroup: "border-lavender-400 space-y-lg ml-16 border-l-2 pl-24",
    subStepHeading: "mb-4 flex items-center gap-10",
  },
});

const {
  searchInput,
  chip,
  termChip,
  lawCard,
  areaCard,
  normRow,
  countBadge,
  matrixHeaderCell,
  matrixRowLabel,
  matrixCell,
  sourceCard,
  stepBadge,
  subStepGroup,
  subStepHeading,
  selectedLawCard,
  infoTrigger,
  infoPopoverPanel,
} = styles();
---

<Layout title={frontmatter.title} description={description} excludeFromSearch>
  <main x-data="rechtErkunden" class="breakout-grid pb-lg">
    <Hero level="main">
      <h1>{frontmatter.title}</h1>
      <p slot="subtitle">{description}</p>
    </Hero>

    <div class="breakout breakout-grid bg-yellow-100 py-8">
      <p class="mb-0">
        <strong>Hinweis:</strong> Dieses Werkzeug ist ein illustrativer Prototyp mit
        erfundenen Beispieldaten. Gesetzesnamen sind real, die dargestellten Verbindungen,
        Zitate, Volltexte und Ähnlichkeits-Werte sind jedoch frei erfunden und nicht
        rechtlich geprüft. Es zeigt, wie eine explorative Rechtsrecherche für Gesetzesvorhaben
        aussehen könnte.
      </p>
    </div>

    {/* Step 1: Zu änderndes Recht bestimmen (Teilschritte 1.1-1.3) */}
    <section class="py-lg space-y-lg">
      <div class="space-y-lg min-w-0">
        <div class="flex items-start gap-16">
          <span class={stepBadge()}>1</span>
          <div>
            <h2 class="mb-4">Zu änderndes Recht bestimmen</h2>
            <p class="kern-subline py-0">
              Bestimmen Sie in drei Teilschritten, welches Gesetz, welches
              Rechtsgebiet und welche konkreten Normen im Rahmen Ihres Vorhabens
              geändert werden sollen.
            </p>
          </div>
        </div>

        <div class={subStepGroup()}>
          {/* 1.1 Gesetz suchen */}
          <div class="space-y-md">
            <div>
              <div class={subStepHeading()}>
                <h3 class="mt-0 mb-0">Gesetz suchen</h3>
              </div>
              <p class="kern-subline py-0">
                Suchen Sie das Gesetz, das Sie im Rahmen Ihres Vorhabens ändern
                möchten.
              </p>
            </div>

            <div class="relative w-full md:max-w-400">
              <Icon
                name="ic:round-search"
                class="text-icon-muted pointer-events-none absolute top-1/2 left-12 h-24 w-24 -translate-y-1/2"
              />
              <input
                class={searchInput()}
                type="search"
                placeholder="z. B. SGB II …"
                aria-label="Gesetz suchen"
                x-model.debounce.300ms="lawQuery"
              />
              <button
                type="button"
                class="text-icon-muted absolute top-1/2 right-12 -translate-y-1/2"
                x-show="lawQuery"
                x-cloak
                aria-label="Suche löschen"
                @click="lawQuery = ''"
              >
                <Icon name="ic:round-close" class="h-24 w-24" />
              </button>
            </div>

            <div
              x-show="!selectedLaw && lawQuery.trim().length > 0 && matchingLaws.length > 0"
              x-cloak
              class="grid gap-12 sm:grid-cols-2 lg:grid-cols-3"
              role="group"
              aria-label="Gesetzesliste"
            >
              <template x-for="law in matchingLaws" :key="law.id">
                <button
                  type="button"
                  class={lawCard()}
                  @click="selectLaw(law.id)"
                >
                  <span class="text-base font-semibold" x-text="law.label"
                  ></span>
                  <span
                    class="text-icon-muted text-xs leading-snug"
                    x-text="law.name"></span>
                </button>
              </template>
            </div>

            <p
              x-show="!selectedLaw && lawQuery.trim() && matchingLaws.length === 0"
              x-cloak
              class="text-icon-muted py-0 italic"
            >
              Keine Gesetze für die aktuelle Suche gefunden.
            </p>

            <p
              x-show="!selectedLaw && !lawQuery.trim()"
              x-cloak
              class="text-icon-muted py-0 italic"
            >
              Geben Sie einen Suchbegriff ein, um Gesetze anzuzeigen.
            </p>

            {/* Selected law */}
            <div x-show="selectedLaw" x-cloak class={selectedLawCard()}>
              <div>
                <p class="kern-label text-icon-muted mb-2">
                  Ausgewähltes Gesetz
                </p>
                <p
                  class="mb-0 text-base font-semibold"
                  x-text="selectedLaw ? selectedLaw.label : ''"
                >
                </p>
                <p
                  class="text-icon-muted py-0 text-xs"
                  x-text="selectedLaw ? selectedLaw.name : ''"
                >
                </p>
              </div>
              <button
                type="button"
                class="kern-btn kern-btn--tertiary shrink-0"
                @click="clearLaw()"
              >
                <span class="kern-label">Anderes Gesetz wählen</span>
              </button>
            </div>

            {/* Fallback: no mock data for the selected law */}
            <div
              x-show="selectedLaw && !selectedLaw.hasData"
              x-cloak
              class="border-lavender-400 bg-lavender-200 flex items-start gap-12 rounded-sm border p-20"
            >
              <Icon
                name="ic:round-info"
                class="text-cosmic-blue-base mt-2 h-24 w-24 shrink-0"
              />
              <div>
                <p class="mt-0 mb-4">
                  Für dieses Gesetz liegen noch keine Analysedaten vor.
                </p>
                <p class="py-0">
                  Prototyp-Daten stehen bislang nur für das SGB II zur
                  Verfügung.
                </p>
                <button
                  type="button"
                  class="kern-btn kern-btn--secondary mt-8"
                  @click="selectLaw('sgb2')"
                >
                  <span class="kern-label"
                    >Beispieldaten zum SGB II anzeigen</span
                  >
                </button>
              </div>
            </div>
          </div>

          {/* 1.2 Rechtsgebiet wählen */}
          <div
            x-show="selectedLaw && selectedLaw.hasData"
            x-cloak
            class="space-y-md"
          >
            <div>
              <div class={subStepHeading()}>
                <h3 class="mt-0 mb-0">Rechtsgebiet wählen</h3>
              </div>
              <p class="kern-subline flex flex-wrap items-center gap-4 py-0">
                <span>
                  Diese Rechtsgebiete werden im ausgewählten Gesetz behandelt.
                </span>
                <span
                  class="relative inline-flex"
                  x-data="{ open: false }"
                  x-on:click.outside="open = false"
                >
                  <button
                    type="button"
                    class={infoTrigger()}
                    x-on:click="open = !open"
                    x-bind:aria-expanded="open"
                    aria-label="Hinweis zur Ermittlung der Rechtsgebiete anzeigen"
                  >
                    <Icon name="ic:outline-info" class="h-16 w-16" />
                  </button>
                  <span
                    x-show="open"
                    x-cloak
                    x-transition
                    class={infoPopoverPanel()}
                  >
                    Im vorgesehenen Verfahren würden die Rechtsgebiete
                    automatisiert über Textanalyse ermittelt (z. B.
                    Keyword-Extraktion, Clustering ähnlicher Normen). Hier sind
                    sie als Beispieldaten hinterlegt.
                  </span>
                </span>
              </p>
            </div>

            <div
              class="grid gap-12 sm:grid-cols-2 lg:grid-cols-3"
              role="group"
              aria-label="Rechtsgebiete"
            >
              {
                LAW_AREAS.map((area) => (
                  <button
                    type="button"
                    class={areaCard()}
                    x-bind:class={`selectedAreaId === '${area.id}' ? 'border-cosmic-blue-base bg-lavender-200 ring-1 ring-cosmic-blue-base' : 'border-lavender-400 bg-white hover:border-cosmic-blue-400'`}
                    x-on:click={`selectArea('${area.id}')`}
                  >
                    <span class="text-base font-semibold">{area.label}</span>
                    <span class="text-icon-muted text-xs leading-snug">
                      {area.description}
                    </span>
                    <span class={countBadge()}>
                      {area.normIds.length} Normen
                    </span>
                  </button>
                ))
              }
            </div>
          </div>

          {/* 1.3 Normen auswählen */}
          <div x-show="selectedArea" x-cloak class="space-y-md">
            <div>
              <div class={subStepHeading()}>
                <h3 class="mt-0 mb-0">Normen auswählen</h3>
              </div>
              <p class="kern-subline py-0">
                Diese Normen des ausgewählten Rechtsgebiets stehen zur Änderung
                an. Deaktivieren Sie einzelne Normen, um das angrenzende Recht
                unten entsprechend einzugrenzen.
              </p>
            </div>

            <ul class="space-y-8" role="list">
              <template x-for="norm in areaNorms" :key="norm.id">
                <li
                  class={normRow()}
                  x-bind:class="isNormActive(norm.id) ? 'border-cosmic-blue-base bg-white' : 'border-lavender-400 bg-lavender-100 opacity-70'"
                >
                  <input
                    type="checkbox"
                    class="kern-form-check__checkbox mt-2 shrink-0"
                    :checked="isNormActive(norm.id)"
                    @change="toggleNorm(norm.id)"
                    :aria-label="`${norm.ref} berücksichtigen`"
                  />
                  <NormDisplay
                    label="norm.ref"
                    title="norm.title"
                    summary="norm.summary"
                    fullText="norm.fullText"
                    url="normUrl(norm)"
                  />
                </li>
              </template>
            </ul>
          </div>
        </div>
      </div>

      {/* Step 2: Angrenzendes Recht erkunden, with shared detail sidebar */}
      <div
        class="grid gap-24 lg:items-start"
        x-bind:class="sidebarMode ? 'lg:grid-cols-[1fr_360px]' : 'lg:grid-cols-1'"
      >
        <div x-show="selectedArea" x-cloak class="space-y-md">
          <div class="flex items-start gap-16">
            <span class={stepBadge()}>2</span>
            <div>
              <h2 class="mb-4">Angrenzendes Recht erkunden</h2>
              <p class="kern-subline py-0">
                Erkunden Sie die Verbindungen der in Schritt 1 ausgewählten
                Normen über gemeinsame Begriffe und Relevanzgründe.
              </p>
            </div>
          </div>

          <div class={subStepGroup()}>
            {/* Begriffe im Fokus strip */}
            <div x-show="activeTerms.length > 0" x-cloak class="space-y-md">
              <div>
                <div class={subStepHeading()}>
                  <h3 class="mt-0 mb-0">Begriffe im Fokus</h3>
                </div>
                <p class="kern-subline py-0">
                  Diese Begriffe verbinden die ausgewählten Normen mit anderen
                  Gesetzen - unabhängig davon, welches Gesetz sie definiert.
                </p>
              </div>
              <div class="flex flex-wrap gap-8">
                <template x-for="term in activeTerms" :key="term.id">
                  <button
                    type="button"
                    class={termChip()}
                    :class="sidebarMode === 'term' && sidebarTermId === term.id ? 'ring-2 ring-cosmic-blue-base' : ''"
                    @click="openTerm(term.id)"
                  >
                    <span x-text="term.term"></span>
                    <span
                      class="text-icon-muted text-xs"
                      x-text="`${termLawCount(term)} ${termLawCount(term) === 1 ? 'Gesetz' : 'Gesetze'}`"
                    ></span>
                  </button>
                </template>
              </div>
            </div>

            <div class="space-y-md">
              <div>
                <div class={subStepHeading()}>
                  <h3 class="mt-0 mb-0">Relevantes Recht explorieren</h3>
                </div>
                <p class="kern-subline py-0">
                  Die Übersicht ordnet angrenzende Gesetze nach Normenhierarchie
                  und Relevanzgrund. Klicken Sie auf ein Gesetz, um die
                  Begründung zu sehen.
                </p>
              </div>

              <p
                x-show="activeNormIds.length === 0"
                x-cloak
                class="text-icon-muted py-0 italic"
              >
                Wählen Sie oben mindestens eine Norm aus, um angrenzendes Recht
                anzuzeigen.
              </p>

              <template x-if="activeNormIds.length > 0">
                <div>
                  <p
                    x-show="visibleRelations.length === 0"
                    x-cloak
                    class="text-icon-muted py-0 italic"
                  >
                    Für die aktuelle Normauswahl wurden keine angrenzenden
                    Gesetze gefunden.
                  </p>

                  <div x-show="visibleRelations.length > 0" x-cloak>
                    {/* Desktop matrix */}
                    <div
                      class="hidden overflow-visible rounded-sm lg:grid"
                      style={`grid-template-columns: 200px repeat(${RELEVANCE_REASONS.length}, 1fr);`}
                    >
                      <div class={matrixHeaderCell()}></div>
                      {
                        RELEVANCE_REASONS.map((reason, index) => (
                          <div class={matrixHeaderCell()}>
                            <span class="inline-flex items-center gap-4 text-base font-semibold">
                              {reason.label}
                              {reason.hint && (
                                <span
                                  class="relative inline-flex"
                                  x-data="{ open: false }"
                                  x-on:click.outside="open = false"
                                >
                                  <button
                                    type="button"
                                    class={infoTrigger()}
                                    x-on:click="open = !open"
                                    x-bind:aria-expanded="open"
                                    aria-label={`Hinweis zu ${reason.label} anzeigen`}
                                  >
                                    <Icon
                                      name="ic:outline-info"
                                      class="h-16 w-16"
                                    />
                                  </button>
                                  <span
                                    x-show="open"
                                    x-cloak
                                    x-transition
                                    role="tooltip"
                                    class={`${infoPopoverPanel()} ${index === RELEVANCE_REASONS.length - 1 ? "right-0 left-auto" : ""}`}
                                  >
                                    {reason.hint}
                                  </span>
                                </span>
                              )}
                            </span>
                            <span
                              class="text-icon-muted mt-2 block text-xs font-normal"
                              x-text={`reasonCount('${reason.id}') + ' Gesetze'`}
                            />
                          </div>
                        ))
                      }

                      {
                        HIERARCHY_LEVELS.map((level) => (
                          <Fragment>
                            <div class={matrixRowLabel()}>
                              <div class="text-base font-semibold">
                                {level.label}
                              </div>
                              <span
                                class="text-icon-muted mt-2 block text-xs font-normal"
                                x-text={`levelCount('${level.id}') + ' Gesetze'`}
                              />
                            </div>
                            {RELEVANCE_REASONS.map((reason) => (
                              <div class={matrixCell()}>
                                <div
                                  class="flex flex-wrap gap-6"
                                  x-show={`matrixCell('${level.id}', '${reason.id}').length > 0`}
                                >
                                  <template
                                    x-for={`relation in matrixCell('${level.id}', '${reason.id}')`}
                                    x-bind:key="relation.id"
                                  >
                                    <button
                                      type="button"
                                      class={chip()}
                                      x-bind:class="sidebarMode === 'evidence' && sidebarRelationId === relation.id ? 'ring-2 ring-cosmic-blue-base' : ''"
                                      x-on:click="openRelation(relation)"
                                    >
                                      <span x-text="relation.lawLabel" />
                                    </button>
                                  </template>
                                </div>
                                <span
                                  class="text-icon-muted"
                                  x-show={`matrixCell('${level.id}', '${reason.id}').length === 0`}
                                >
                                  –
                                </span>
                              </div>
                            ))}
                          </Fragment>
                        ))
                      }
                    </div>

                    {/* Mobile: stacked by hierarchy level */}
                    <div class="space-y-16 lg:hidden">
                      {
                        HIERARCHY_LEVELS.map((level) => (
                          <div
                            x-show={`levelCount('${level.id}') > 0`}
                            x-cloak
                            class="border-lavender-400 rounded-sm border p-12"
                          >
                            <div class="mb-8 flex items-center justify-between gap-8">
                              <h4 class="mt-0 mb-0">{level.label}</h4>
                              <span
                                class={countBadge()}
                                x-text={`levelCount('${level.id}') + ' Gesetze'`}
                              />
                            </div>
                            {RELEVANCE_REASONS.map((reason) => (
                              <div
                                x-show={`matrixCell('${level.id}', '${reason.id}').length > 0`}
                                x-cloak
                                class="mb-12 last:mb-0"
                              >
                                <p class="kern-label text-icon-muted mb-4">
                                  {reason.label}
                                </p>
                                <div class="flex flex-wrap gap-6">
                                  <template
                                    x-for={`relation in matrixCell('${level.id}', '${reason.id}')`}
                                    x-bind:key="relation.id"
                                  >
                                    <button
                                      type="button"
                                      class={chip()}
                                      x-bind:class="sidebarMode === 'evidence' && sidebarRelationId === relation.id ? 'ring-2 ring-cosmic-blue-base' : ''"
                                      x-on:click="openRelation(relation)"
                                    >
                                      <span x-text="relation.lawLabel" />
                                    </button>
                                  </template>
                                </div>
                              </div>
                            ))}
                          </div>
                        ))
                      }
                    </div>
                  </div>
                </div>
              </template>
            </div>
          </div>
        </div>

        {/* Shared detail sidebar: norm / term / evidence mode */}
        <div>
          <div
            class="fixed inset-0 z-40 bg-black/40 lg:hidden"
            x-show="sidebarMode"
            x-cloak
            aria-hidden="true"
            @click="closeSidebar()"
          >
          </div>

          <aside
            x-show="sidebarMode"
            x-cloak
            class="border-lavender-400 fixed inset-x-0 bottom-0 z-50 max-h-[85vh] overflow-y-auto rounded-t-sm border-t bg-white p-20 shadow-lg lg:sticky lg:top-24 lg:z-auto lg:max-h-[calc(100vh-96px)] lg:rounded-sm lg:border lg:shadow-none"
            aria-label="Details"
          >
            <div class="mb-12 flex items-start justify-between gap-12">
              <h3 class="mt-0 mb-0">
                <span
                  x-text="sidebarMode === 'norm' ? 'Normtext' : sidebarMode === 'term' ? 'Begriff' : 'Warum relevant?'"
                ></span>
              </h3>
              <button
                type="button"
                class="text-icon-muted shrink-0"
                aria-label="Schließen"
                @click="closeSidebar()"
              >
                <Icon name="ic:round-close" class="h-24 w-24" />
              </button>
            </div>

            {/* Norm mode */}
            <template x-if="sidebarMode === 'norm' && sidebarNorm">
              <NormDisplay
                label="sidebarNorm.ref"
                title="sidebarNorm.title"
                summary="sidebarNorm.summary"
                fullText="sidebarNorm.fullText"
                url="normUrl(sidebarNorm)"
                bordered
              />
            </template>

            {/* Term mode */}
            <template x-if="sidebarMode === 'term' && sidebarTerm">
              <div class="space-y-12">
                <div>
                  <p
                    class="mt-0 mb-4 text-base font-semibold"
                    x-text="sidebarTerm.term"
                  >
                  </p>
                  <p class="py-0 text-sm" x-text="sidebarTerm.definition"></p>
                </div>

                <div>
                  <p class="kern-label text-icon-muted mb-8">Definiert in</p>
                  <NormDisplay
                    label="sidebarTerm.definedIn.label"
                    fullText="sidebarTerm.definedIn.fullText"
                    url="sidebarTerm.definedIn.url"
                    bordered
                  />
                </div>

                <div>
                  <p class="kern-label text-icon-muted mb-8">Verwendet in</p>
                  <ul class="list-none space-y-8 p-0" role="list">
                    <template
                      x-for="(entry, index) in sidebarTerm.usedIn.adjacentNorms"
                      :key="index"
                    >
                      <li>
                        <span
                          class="mb-4 inline-block rounded-full px-10 py-2 text-xs font-semibold"
                          x-bind:class="levelBadgeClass(entry.level)"
                          x-text="levelLabel(entry.level)"></span>
                        <NormDisplay
                          label="entry.ref.label"
                          fullText="entry.ref.fullText"
                          url="entry.ref.url"
                          bordered
                        />
                      </li>
                    </template>
                  </ul>
                </div>
              </div>
            </template>

            {/* Evidence mode */}
            <template x-if="sidebarMode === 'evidence' && sidebarRelation">
              <div class="space-y-12">
                <div>
                  <p
                    class="mt-0 mb-4 text-base font-semibold"
                    x-text="sidebarRelation.lawName"
                  >
                  </p>
                  <div class="flex flex-wrap items-center gap-6">
                    <span
                      class="inline-flex items-center rounded-full px-10 py-2 text-xs font-semibold"
                      x-bind:class="levelBadgeClass(sidebarRelation.level)"
                      x-text="levelLabel(sidebarRelation.level)"></span>
                    <span
                      class="text-icon-muted text-xs"
                      x-text="reasonFullLabel(sidebarRelation.reason)"></span>
                  </div>
                </div>

                <div x-show="sidebarRelation.nlp" x-cloak class={sourceCard()}>
                  <p class="kern-label text-icon-muted mb-4">
                    Ähnlichkeitssignal (NLP, Prototyp-Daten)
                  </p>
                  <p class="mb-4 py-0 text-sm">
                    Themenähnlichkeit: <span
                      class="font-semibold"
                      x-text="sidebarRelation.nlp ? sidebarRelation.nlp.similarity.toFixed(2).replace('.', ',') : ''"
                    ></span>
                  </p>
                  <div class="flex flex-wrap gap-6">
                    <template
                      x-for="keyword in sidebarRelation.nlp ? sidebarRelation.nlp.keywords : []"
                      :key="keyword"
                    >
                      <span
                        class="bg-lavender-100 text-cosmic-blue-base rounded-full px-8 py-2 text-xs"
                        x-text="keyword"></span>
                    </template>
                  </div>
                </div>

                <div>
                  <p class="kern-label text-icon-muted mb-8">
                    Betroffene SGB-II-Normen
                  </p>
                  <div class="space-y-8">
                    <template
                      x-for="normId in sidebarRelation.normIds"
                      :key="normId"
                    >
                      <NormDisplay
                        label="normById(normId).ref"
                        title="normById(normId).title"
                        summary="normById(normId).summary"
                        fullText="normById(normId).fullText"
                        url="normUrl(normById(normId))"
                        onTitleClick="openNorm(normId)"
                        bordered
                      />
                    </template>
                  </div>
                </div>

                <div>
                  <p class="kern-label text-icon-muted mb-8">Begründung</p>
                  <ul class="list-none space-y-12 p-0" role="list">
                    <template
                      x-for="(item, index) in sidebarRelation.evidence"
                      :key="index"
                    >
                      <li class="space-y-8">
                        <p class="py-0 text-sm" x-text="item.quote"></p>
                        <NormDisplay
                          label="item.adjacentNorm.label"
                          fullText="item.adjacentNorm.fullText"
                          url="item.adjacentNorm.url"
                          bordered
                        />

                        {
                          /* cited in - only for "gemeinsame_nennung" evidence */
                        }
                        <div
                          x-show="item.citedIn"
                          x-cloak
                          x-data="{ open: false }"
                          class="border-lavender-400 mt-8 border-t pt-8"
                        >
                          <p
                            class="kern-label text-icon-muted mb-4"
                            x-text="item.citedIn && item.citedIn.kind === 'literatur' ? 'Fundstelle (Literatur)' : 'Fundstelle (Rechtsprechung)'"
                          >
                          </p>
                          <div class="flex items-center justify-between gap-8">
                            <p
                              class="mb-0 text-sm font-semibold"
                              x-text="item.citedIn ? item.citedIn.label : ''"
                            >
                            </p>
                            <div class="flex shrink-0 items-center gap-8">
                              <a
                                x-show="item.citedIn && item.citedIn.url && item.citedIn.url !== '#'"
                                x-cloak
                                :href="item.citedIn ? item.citedIn.url : '#'"
                                target="_blank"
                                rel="noopener"
                                class="text-icon-muted hover:text-cosmic-blue-base"
                                aria-label="Quelle öffnen"
                              >
                                <Icon name="ic:round-gavel" class="h-18 w-18" />
                              </a>
                              <button
                                type="button"
                                class="text-cosmic-blue-base text-xs font-semibold whitespace-nowrap"
                                @click="open = !open"
                              >
                                <span
                                  x-text="open ? 'Volltext ausblenden' : 'Volltext anzeigen'"
                                ></span>
                              </button>
                            </div>
                          </div>
                          <p
                            x-show="open"
                            x-cloak
                            class="text-icon-muted mt-4 py-0 text-sm whitespace-pre-line"
                            x-text="item.citedIn ? item.citedIn.fullText : ''"
                          >
                          </p>
                        </div>
                      </li>
                    </template>
                  </ul>
                </div>
              </div>
            </template>
          </aside>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>

<script>
  import Alpine from "alpinejs";
  import {
    SEARCHABLE_LAWS,
    LAW_AREAS,
    NORMS,
    RELATIONS,
    TERMS,
    HIERARCHY_LEVELS,
    RELEVANCE_REASONS,
    type SearchableLaw,
    type LawArea,
    type Norm,
    type Relation,
    type Term,
    type HierarchyLevel,
    type RelevanceReason,
  } from "./_recht-erkunden-data";

  type SidebarMode = "norm" | "evidence" | "term" | null;

  const LEVEL_BADGE_BASE = "inline-flex items-center";
  const LEVEL_BADGE_COLORS: Record<HierarchyLevel, string> = {
    grundgesetz: "bg-cosmic-blue-base text-white",
    eu: "bg-indigo-600 text-white",
    bundesgesetz: "bg-lavender-base text-cosmic-blue-base",
    bundesverordnung: "bg-lavender-200 text-cosmic-blue-base",
    landesrecht: "bg-yellow-200 text-yellow-900",
  };

  document.addEventListener("alpine:init", () => {
    Alpine.data("rechtErkunden", () => ({
      lawQuery: "",
      selectedLawId: null as string | null,
      selectedAreaId: null as string | null,
      activeNormIds: [] as string[],
      sidebarMode: null as SidebarMode,
      sidebarNormId: null as string | null,
      sidebarRelationId: null as string | null,
      sidebarTermId: null as string | null,

      get matchingLaws(): SearchableLaw[] {
        const query = this.lawQuery.trim().toLowerCase();
        if (!query) return [];
        return SEARCHABLE_LAWS.filter(
          (law) =>
            law.label.toLowerCase().includes(query) ||
            law.name.toLowerCase().includes(query),
        );
      },

      get selectedLaw(): SearchableLaw | null {
        return (
          SEARCHABLE_LAWS.find((law) => law.id === this.selectedLawId) ?? null
        );
      },

      selectLaw(id: string) {
        this.selectedLawId = id;
        this.lawQuery = "";
        this.selectedAreaId = null;
        this.activeNormIds = [];
        this.closeSidebar();
      },

      clearLaw() {
        this.selectedLawId = null;
        this.selectedAreaId = null;
        this.activeNormIds = [];
        this.closeSidebar();
      },

      selectArea(id: string) {
        this.selectedAreaId = id;
        const area = LAW_AREAS.find((entry) => entry.id === id);
        this.activeNormIds = area ? [...area.normIds] : [];
        this.closeSidebar();
      },

      get selectedArea(): LawArea | null {
        return (
          LAW_AREAS.find((entry) => entry.id === this.selectedAreaId) ?? null
        );
      },

      get areaNorms(): Norm[] {
        const area = this.selectedArea;
        if (!area) return [];
        return area.normIds
          .map((id) => NORMS.find((norm) => norm.id === id))
          .filter((norm): norm is Norm => Boolean(norm));
      },

      isNormActive(id: string) {
        return this.activeNormIds.includes(id);
      },

      toggleNorm(id: string) {
        if (this.activeNormIds.includes(id)) {
          this.activeNormIds = this.activeNormIds.filter(
            (entry) => entry !== id,
          );
        } else {
          this.activeNormIds = [...this.activeNormIds, id];
        }
      },

      get visibleRelations(): Relation[] {
        if (this.activeNormIds.length === 0) return [];
        return RELATIONS.filter((relation) =>
          relation.normIds.some((id) => this.activeNormIds.includes(id)),
        );
      },

      matrixCell(level: HierarchyLevel, reason: RelevanceReason): Relation[] {
        return this.visibleRelations.filter(
          (relation) => relation.level === level && relation.reason === reason,
        );
      },

      levelCount(level: HierarchyLevel) {
        return this.visibleRelations.filter(
          (relation) => relation.level === level,
        ).length;
      },

      reasonCount(reason: RelevanceReason) {
        return this.visibleRelations.filter(
          (relation) => relation.reason === reason,
        ).length;
      },

      get activeTerms(): Term[] {
        if (this.activeNormIds.length === 0) return [];
        return TERMS.filter((term) =>
          term.usedIn.normIds.some((id) => this.activeNormIds.includes(id)),
        );
      },

      termLawCount(term: Term) {
        return new Set(term.usedIn.adjacentNorms.map((entry) => entry.lawLabel))
          .size;
      },

      openNorm(id: string) {
        this.sidebarMode = "norm";
        this.sidebarNormId = id;
        this.sidebarRelationId = null;
        this.sidebarTermId = null;
      },

      openRelation(relation: Relation) {
        this.sidebarMode = "evidence";
        this.sidebarRelationId = relation.id;
        this.sidebarNormId = null;
        this.sidebarTermId = null;
      },

      openTerm(id: string) {
        this.sidebarMode = "term";
        this.sidebarTermId = id;
        this.sidebarNormId = null;
        this.sidebarRelationId = null;
      },

      closeSidebar() {
        this.sidebarMode = null;
        this.sidebarNormId = null;
        this.sidebarRelationId = null;
        this.sidebarTermId = null;
      },

      get sidebarNorm(): Norm | null {
        return NORMS.find((norm) => norm.id === this.sidebarNormId) ?? null;
      },

      get sidebarRelation(): Relation | null {
        return (
          RELATIONS.find(
            (relation) => relation.id === this.sidebarRelationId,
          ) ?? null
        );
      },

      get sidebarTerm(): Term | null {
        return TERMS.find((term) => term.id === this.sidebarTermId) ?? null;
      },

      normById(id: string): Norm | null {
        return NORMS.find((norm) => norm.id === id) ?? null;
      },

      normUrl(norm: Norm | null) {
        if (!norm) return "";
        const section = norm.id.replace("n-sgb2-", "");
        return `https://www.gesetze-im-internet.de/sgb_2/__${section}.html`;
      },

      levelLabel(level: HierarchyLevel) {
        return (
          HIERARCHY_LEVELS.find((entry) => entry.id === level)?.label ?? level
        );
      },

      levelBadgeClass(level: HierarchyLevel) {
        return `${LEVEL_BADGE_BASE} ${LEVEL_BADGE_COLORS[level] ?? ""}`;
      },

      reasonLabel(reason: RelevanceReason) {
        return (
          RELEVANCE_REASONS.find((entry) => entry.id === reason)?.label ??
          reason
        );
      },

      reasonFullLabel(reason: RelevanceReason) {
        const entry = RELEVANCE_REASONS.find((item) => item.id === reason);
        return entry?.fullLabel ?? entry?.label ?? reason;
      },
    }));
  });
</script>
