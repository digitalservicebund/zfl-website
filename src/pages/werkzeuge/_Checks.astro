---
import ToolCard from "./_ToolCard.astro";
import digitalcheckImage from "./Digitalcheck.png";
import eGesetzgebungImage from "./eGesetzgebung.png";
import eNormImage from "./eNorm.jpg";
import fimImage from "./FIM.png";
import interoperableEuropeImage from "./InteroperableEurope.png";
import rulemapBuilderImage from "./RulemapBuilder.jpg";
---

<div class="gap-md grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
  <ToolCard
    title="Digitalcheck"
    href="https://digitalcheck.bund.de/"
    subline="Digitale Regelungen erarbeiten"
    body="Der Digitalcheck ist eine Prozessbegleitung für Ihr Regelungsvorhaben. Sie stellen damit Digitaltauglichkeit sicher."
    image={digitalcheckImage}
    imageAlt="Symbolbild für den Digitalcheck"
  />
  <ToolCard
    title="Rulemap Builder"
    href="https://rulemapping.org/de"
    subline="Regelungen als Entscheidungsmodelle erstellen"
    body="Rulemaps machen die Logik von Gesetzen sichtbar, prüfbar und anwendbar – und schaffen so die Grundlage für eine Verwaltung, die nachvollziehbar, effizient und modern arbeitet."
    image={rulemapBuilderImage}
    imageAlt="Symbolbild für den Rulemap Builder"
    imageSource="Rulemapping Group"
  />
  <ToolCard
    title="E-Gesetzgebung"
    href="https://plattform.egesetzgebung.bund.de/cockpit/"
    subline="Das Rechtsetzungsverfahren auf Bundesebene"
    body="Die E-Gesetzgebung ermöglicht die durchgängig digitale Zusammenarbeit im Gesetzgebungsverfahren zwischen Bundesregierung, Bundesrat und Bundestag."
    image={eGesetzgebungImage}
    imageAlt="Symbolbild für die E-Gesetzgebung"
    imageSource="BMI"
  />
  <ToolCard
    title="eNorm"
    href="https://www.enorm.bund.de/"
    subline="Elektronische Arbeitshilfen und Verkündung"
    body="Die eNorm unterstützt bei der Einhaltung rechtsförmlicher und redaktioneller Vorgaben bei der Erstellung von Regelungsentwürfen. Sie automatisiert darüber hinaus bestimmte Routineaufgaben."
    image={eNormImage}
    imageAlt="Interface der eNorm"
    imageSource="BMJV"
  />
  <ToolCard
    title="FIM – Föderales Informations­management"
    href="https://fimportal.de/"
    subline="Der Standard für Verwaltungsleistungen"
    body="Mit dem Föderalen Informationsmanagement (FIM) erfassen Bund, Länder und Kommunen Informationen über Verwaltungshandeln strukturiert und zugänglich. FIM stellt einheitliche Datenfelder, standardisierte Prozessvorgaben und leicht verständliche Bürgerinformationen bereit."
    image={fimImage}
    imageAlt="Symbolbild für das Föderale Informationsmanagement"
    imageSource="FITKO"
  />
  <ToolCard
    title="Interoperabilitäts-Bewertungen"
    href="https://digitalcheck.bund.de/interoperabel"
    subline="EU-Interoperabilität prüfen"
    body="Hier erfahren Sie, was die Verordnung für ein interoperables Europa (EU) 2024/903 für Ihr Regelungsvorhaben bedeutet und wie sie zu einem vernetzten Europa beiträgt."
    image={interoperableEuropeImage}
    imageAlt="Symbolbild für ein vernetztes Europa"
  />
</div>
