---
import SearchModal from "@/components/search/SearchModal.astro";
import Footer from "@/components/global/Footer.astro";
import PageHeader from "@/components/global/PageHeader.astro";
import SectionSidebar from "@/components/global/SectionSidebar.astro";
import Posthog from "@/components/global/Posthog.astro";
import { isProduction } from "@/config/stage";
import { getSectionNavigation } from "@/utils/navigation/drilldown";
import firaSansMediumUrl from "@kern-ux/native/dist/fonts/fira-sans/FiraSans-Medium.woff2?url";
import firaSansRegularUrl from "@kern-ux/native/dist/fonts/fira-sans/FiraSans-Regular.woff2?url";
import { SEO } from "astro-seo";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  noFooter?: boolean;
  excludeFromSearch?: boolean;
  pagefindWeight?: number;
}

const {
  title: pageTitle,
  description,
  noFooter,
  excludeFromSearch,
  pagefindWeight,
} = Astro.props;

const siteName = "Zentrum für Legistik";
const title = pageTitle ? `${pageTitle} — ${siteName}` : siteName;
const SEOImage = `${Astro.url.origin}/SEO_ZfL.png`;
const showSectionSidebar = getSectionNavigation(Astro.url.pathname) !== null;

const defaultDescription =
  "Das Zentrum für Legistik unterstützt Sie bei der Ausarbeitung von Regelungen. Sie stellen damit sicher, dass Ihr Vorhaben betroffenenzentriert, praxistauglich und digital umsetzbar ist.";
---

<!doctype html>
<html lang="de" data-kern-theme="light">
  {/* disable dark mode for now*/}

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <link
    rel="preload"
    href={firaSansRegularUrl}
    as="font"
    type="font/woff2"
    crossorigin
  />
  <link
    rel="preload"
    href={firaSansMediumUrl}
    as="font"
    type="font/woff2"
    crossorigin
  />

  <SEO
    title={title}
    description={description ?? defaultDescription}
    openGraph={{
      basic: {
        title,
        type: "website",
        image: SEOImage,
      },
    }}
    extend={{
      link: [
        { rel: "icon", href: "/favicon.svg" },
        { rel: "sitemap", href: "/sitemap-index.xml" },
      ],
      meta: [
        { name: "twitter:title", content: title },
        {
          name: "twitter:image",
          content: SEOImage,
        },
      ],
    }}
  />

  <body class="relative">
    <PageHeader />
    <div
      data-pagefind-default-meta="pageType:Seite"
      {...!excludeFromSearch && { "data-pagefind-body": "" }}
      {...pagefindWeight && { "data-pagefind-weight": pagefindWeight }}
    >
      {
        showSectionSidebar ? (
          <div class="h-full min-[900px]:grid min-[900px]:grid-cols-[300px_minmax(0,1fr)]">
            <SectionSidebar>
              <slot name="section-sidebar-extra" slot="extra" />
            </SectionSidebar>
            <slot />
          </div>
        ) : (
          <slot />
        )
      }
    </div>
    {!noFooter && <Footer />}
    <SearchModal />
    {isProduction && <Posthog />}
  </body>
</html>
