{
  "name": "zentrum-fuer-legistik",
  "type": "module",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "audit:licences": "license-checker-rseidelsohn --production --excludePrivatePackages --onlyAllow 'MIT;BSD-3-Clause;BSD-2-Clause;0BSD;ISC;Apache-2.0;MPL-2.0;BlueOak-1.0.0;Custom: LICENSE;Unlicense;EUPL-1.2;Python-2.0;CC0-1.0' --summary",
    "build": "pnpm sync && astro build",
    "build:search-index": "[ ! -d \"dist\" ] && pnpm build || true",
    "clean": "rm -rf dist",
    "clean:deps": "pnpm knip",
    "dev": "pnpm sync && pnpm build:search-index && PUBLIC_STAGE=development astro dev",
    "dev:preview": "PUBLIC_STAGE=preview PREVIEW_BASE_PATH=/preview astro dev",
    "docker:build": "docker build --load -t zfl-website .",
    "docker:run": "docker run -d -p 8080:8080 --name zfl-website zfl-website:latest",
    "docker:stop": "docker stop zfl-website || true && docker rm zfl-website",
    "docker:dev": "pnpm run docker:build && npm run docker:run",
    "docker:logs": "docker logs -f zfl-website",
    "laws:prepare-corpus": "./scripts/run_pipeline_python.sh scripts/prepare_law_corpus.py",
    "laws:build-registry": "./scripts/run_pipeline_python.sh scripts/build_law_registry.py",
    "laws:validate-registry": "./scripts/run_pipeline_python.sh scripts/validate_law_registry.py",
    "laws:build-paragraphs": "./scripts/run_pipeline_python.sh scripts/build_norm_paragraphs.py",
    "laws:download": "./scripts/run_pipeline_python.sh scripts/download_laws.py",
    "laws:fetch-metadata": "./scripts/run_pipeline_python.sh scripts/fetch_gii_metadata.py",
    "laws:extract-obligations": "./scripts/run_pipeline_python.sh scripts/extract_obligations.py",
    "laws:concat-obligations": "./scripts/run_pipeline_python.sh scripts/concat_obligations_csv.py",
    "laws:build-relations": "./scripts/run_pipeline_python.sh scripts/build_law_relations.py",
    "laws:publish-ui-data": "./scripts/run_pipeline_python.sh scripts/publish_laws_ui_data.py",
    "format": "prettier --check",
    "format:fix": "pnpm run format:fix-selected .",
    "format:fix-selected": "prettier --write --ignore-unknown",
    "lint": "eslint",
    "lint:fix": "eslint --fix .",
    "pagefind:debug": "pagefind --site dist --verbose --serve --include-characters \".\" --exclude-selectors \"[href^='mailto:']\"",
    "preinstall": "echo 'Please disable script execution for security reasons: npm config set ignore-scripts true' && exit 1",
    "preview": "astro preview",
    "test": "vitest run",
    "test:a11y": "pnpm run build && playwright test --project=chromium e2e/a11y.spec.ts",
    "test:e2e": "pnpm run build && playwright test --project=chromium",
    "typecheck": "pnpm sync && astro check",
    "sync": "astro sync"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^1.0.0",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/sitemap": "^3.7.3",
    "@iconify-json/ic": "^1.2.4",
    "@kern-ux/native": "^2.6.4",
    "@pagefind/component-ui": "^1.5.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.15.12",
    "astro": "^7.0.7",
    "astro-icon": "^1.1.5",
    "astro-pagefind": "^2.0.1",
    "astro-route-generator": "github:digitalservicebund/astro-route-generator",
    "astro-seo": "^1.1.0",
    "pagefind": "^1.5.2",
    "posthog-js": "^1.399.2",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.3",
    "@playwright/test": "^1.61.1",
    "@types/jsdom": "^28.0.3",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/browser-playwright": "^4.1.10",
    "astro-eslint-parser": "^3.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^3.0.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.26.0",
    "license-checker-rseidelsohn": "^5.0.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.11.0"
}
