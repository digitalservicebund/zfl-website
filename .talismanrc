fileignoreconfig:
  - filename: .env.example
    ignore_detectors:
      - filename
  - filename: .github/workflows/check-and-unit-test.yml
    allowed_patterns:
      - "key:"
  - filename: .github/workflows/pipeline.yml
    allowed_patterns:
      - GITOPS_DIGITALCHECK_APP_ID
      - GITOPS_DIGITALCHECK_APP_PRIVATE_KEY
      - secrets
      - "github_app_private_key:"
      - "password: \\${{  }}"
  - filename: .github/workflows/check-and-unit-test.yml
    allowed_patterns:
      - "key:"
  - filename: .github/workflows/playwright.yml
    allowed_patterns:
      - "key:"
  - filename: .github/workflows/scan.yml
    allowed_patterns:
      - "key:"
      - "TRIVY_PASSWORD: \\${{  }}"
  - filename: AGENTS.md
    checksum: 10062bc4ca6a68e151dc351cf1a06719bb5fef19dd6e98710a2c9a15fc2f1a8f
  - filename: package.json # astro-route-generator commit sha misinterpreted as potential secret
    ignore_detectors: [filecontent]
  - filename: doc/adr/0007-use-posthog-reverse-proxy.md
    allowed_patterns:
      - "IP Masking: The proxy will be configured to drop unnecessary headers, including
        `X-Forwarded-For`, before passing the request to PostHog."
  - filename: doc/routes.md
    allowed_patterns:
      - key
  - filename: src/config/routes.ts
    allowed_patterns:
      - key
  - filename: src/utils/navigation/drilldown.ts
    allowed_patterns:
      - key
  - filename: src/utils/navigation/navigation.test.ts
    allowed_patterns:
      - key
  - filename: nginx/nginx.template.conf
    allowed_patterns:
      - proxy_pass
      - sha256-[^\s]+
  - filename: sonar-project.properties
    allowed_patterns:
      - projectKey
  - filename: src/config/posthog.ts
    checksum: 2c449a89d7fa9be57170bc960a30f51381f9a5d8d046605a6e30c083886163dd
  - filename: src/env.d.ts
    checksum: 8acdc07029e3aed3f44556780790d7a2191e8877c5b114a3147423507385fbec
