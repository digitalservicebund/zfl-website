scopeconfig:
  - scope: node
allowed_patterns:
  - \@[a-z0-9]{40} # Allow fixing action hashes
  - "secrets: inherit"
  - 'key: \${{ runner.os }}'
  - public key
  - secrets.GITHUB_TOKEN
  - posthogKey
  - secret-scan
  - routeKey
  - RouteKey
  - toRouteKey
  - "route key"
  - RouteMetaKey
  - childKey
  - parentKey
  - getRouteByKey
  - keydown
  - KeyDown
  - keyboard
  - Keyboard
  - keyword
  - Keyword
  - fuzzyKeyword
  - :key=
  - aria-keyshortcuts
version: "1.0"
