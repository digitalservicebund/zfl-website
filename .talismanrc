    checksum: 4b4529c26f6b4cd3a5d4a1d0706d8a83dcdd523631ba5f55efc23517b0a3a558
  - filename: scripts/concat_obligations_csv.py
    checksum: 6163e7dca5499a1bc0dfa691ceda7e9581a4e2151bd247ffa7ca6070dd3388d0
  - filename: scripts/PFLICHTEN_README.md
    checksum: 5ebe50571a2b33090cc263c435bbedcf164cc7980a3d12989a03711f0791c500
