    checksum: d91b8729505983b35914335a9f72da8a0786969daebc7dc4a62c976b80d14d13
  - filename: public/data/laws.json
    checksum: fb64e37561e3d4303bdd3792ef045df59e29ddd137f88d2b90490ba2b284a7e6
