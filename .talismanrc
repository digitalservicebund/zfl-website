fileignoreconfig:
  - filename: .env.example
    ignore_detectors:
      - filename
  - filename: .github/workflows/check-and-unit-test.yml
    allowed_patterns:
      - "key:"
  - filename: .github/workflows/pipeline.yml
    allowed_patterns:
      - GITOPS_DIGITALCHECK_APP_ID
      - GITOPS_DIGITALCHECK_APP_PRIVATE_KEY
      - secrets
      - "github_app_private_key:"
      - "password: \\${{  }}"
  - filename: .github/workflows/check-and-unit-test.yml
    allowed_patterns:
      - "key:"
  - filename: .github/workflows/playwright.yml
    allowed_patterns:
      - "key:"
  - filename: .github/workflows/scan.yml
    allowed_patterns:
      - "key:"
      - "TRIVY_PASSWORD: \\${{  }}"
  - filename: AGENTS.md
    checksum: 62a655d53df765c2111c2953222b1242075a14631d8e2a796c4a900924cef1aa
  - filename: doc/adr/0004-configuration-management.md
    checksum: 367a262dfe679ea3254c86879a09d98b0e03863b4c514f58ccd3609afb58bdae
  - filename: doc/adr/0007-use-posthog-reverse-proxy.md
    allowed_patterns:
      - "IP Masking: The proxy will be configured to drop unnecessary headers, including
        `X-Forwarded-For`, before passing the request to PostHog."
  - filename: doc/routes.md
    allowed_patterns:
      - key
  - filename: integrations/routeGenerator.ts
    allowed_patterns:
      - key
  - filename: integrations/routeGenerator.test.ts
    allowed_patterns:
      - key
  - filename: src/config/routes.ts
    allowed_patterns:
      - key
  - filename: src/utils/navigation/drilldown.ts
    allowed_patterns:
      - key
  - filename: src/utils/navigation/navigation.test.ts
    allowed_patterns:
      - key
  - filename: integrations/routeGeneration/extractRouteMeta.ts
    allowed_patterns:
      - key
  - filename: nginx/nginx.template.conf
    allowed_patterns:
      - proxy_pass
      - sha256-[^\s]+
  - filename: sonar-project.properties
    allowed_patterns:
      - projectKey
  - filename: src/config/posthog.ts
    checksum: 2c449a89d7fa9be57170bc960a30f51381f9a5d8d046605a6e30c083886163dd
  - filename: src/env.d.ts
    checksum: 8acdc07029e3aed3f44556780790d7a2191e8877c5b114a3147423507385fbec
  - filename: integrations/routeGenerator.ts
    allowed_patterns:
      - key
  - filename: doc/adr/0004-configuration-management.md
    checksum: 367a262dfe679ea3254c86879a09d98b0e03863b4c514f58ccd3609afb58bdae
  - filename: src/pages/ueber-uns/Ansatz.jpg
    checksum: cf2bcceb403ca3838e988111c1da328a2af9956966f16359ed55c8ece29dac96
  - filename: src/pages/ueber-uns/Zusammenarbeit.png
    checksum: 833102602ab7800701350413f143ac30c20e9c016c5a68eb6c0841d1e5f3561d
  - filename: src/pages/kontakt/computer.jpg
    checksum: 585af9a443434b8caf56dae715544745714fff5e0c4b5d2cc202275950e3a684
  - filename: src/components/global/DebugGrid.astro
    allowed_patterns:
      - \@keydown
scopeconfig:
  - scope: node
allowed_patterns:
  - \@[a-z0-9]{40} # Allow fixing action hashes
  - "secrets: inherit"
  - 'key: \${{ runner.os }}'
  - public key
  - secrets.GITHUB_TOKEN
  - posthogKey
  - secret-scan
  - routeKey
  - RouteKey
  - toRouteKey
  - "route key"
  - RouteMetaKey
  - childKey
  - parentKey
  - getRouteByKey
  - keydown
version: "1.0"
